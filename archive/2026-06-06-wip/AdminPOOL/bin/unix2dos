#!/bin/sh
# script to call unix2dos in the old style, i.e.
#   unix2dos inputfile outputfile
# requires package tofrodos under Linux

inputfile=$1 #the first argument
outputfile=$2 #the second argument

if [ "$inputfile" = "" ]
  then
    exit
fi


if [ "$outputfile" = "" ]
  then
    exit
fi

if [ -f $inputfile ]
  then
   if [ -x /usr/bin/todos ]; then
     todos $inputfile
   fi
   cp $inputfile $outputfile
fi











