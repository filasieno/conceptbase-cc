#!/bin/bash
# commit changes of the current directory to GIT repository

# exit on error
set -e

INGITDIR=`git rev-parse --is-inside-work-tree`

if [ ! "$INGITDIR" = "true" ]; then
  echo "Not in a GIT directory"
  exit 1
fi

CURRENTBRANCH=`git branch | grep \* | cut -d ' ' -f2`

if [ "$1" != "" ]; then
  GITBRANCH = $1
fi


# 1: add the changed files to commit set
git add .
# 2: prepare the commit
git commit
# 3: upload the commit to rep
git push origin $CURRENTBRANCH


