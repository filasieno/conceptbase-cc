# ---------------------------------------------------------------------
#  Revision     : $Revision: 14.5 $ is $State: Exp $
#  Last Change  : $Date: 2015/04/21 15:07:33 $ by $Autor$  
# ---------------------------------------------------------------------


# variant
# -------------------------------------------------------------------
# ermittelt aus `uname -a` output die aktuelle Variante:
#
# z.B:   SunOS barks 5.4 Generic_101945-27 sun4m sparc
# Args:  $1    $2    $3  $4                $5    $6

variant() {
  if [ $1 = Linux ]; then
      if [ `uname -m` = x86_64 ]; then
         echo linux64
         return 0;
      fi;
      if [ `uname -m` = armv6l ]; then
         echo linuxarm
         return 0;
      fi;
      if [ `uname -m` = armv7l ]; then
         echo linuxarm
         return 0;
      fi;
      echo linux
      return 0;
  fi;

 if [ $1 = Darwin ]; then
      echo mac
      return 0;
  fi;

  if [ $# -lt 5 ] ; then
	echo "$0: ERROR: unable to detect system type '$*' !" >&2
  	return 1;
  fi;

  if [ $1 != SunOS ] || [ $3 -lt 5 ]; then
  	echo "$0: WARNING: $1-$3 is not supported !" >&2
  fi;

  case $5 in 
    sun4*)
  	echo sun4
  	;;
    i86pc*)
	  echo i86pc
  	;;
    *)
	  echo "$0: ERROR: machine type $5 is not supported !" >&2
  	return 1;
  	;;
  esac;  
}


if [ `uname` = CYGWIN_NT-5.1 ]; then
   {
   echo cygwin
   }
  else
   {
   eval variant ${UNAME:-'`uname -a`'}
   }
fi

