checkCorrectID(_l,_id) :-
  name2id(_l,_id),
  !.

checkCorrectID(_l,_id) :-
  name2id(_l,_id1),
  put(7),write('!!! ALARM !!! WRONG OBJECT ID in Literals.pro: '),write([_l,current(_id1),expected(_id)]),
  write(' INFORM CONCEPTBASE DEVELOPERS!'),nl,
  !.




checkCorrectID(_name,_label,_id) :-
  getCC(_name,_label,_id1),
  _id1=_id,
  !.

checkCorrectID(_name,_label,_id) :-
  getCC(_name,_label,_id1),
  put(7),write('!!! ALARM !!! WRONG OBJECT ID in Literals.pro: '),write([_name,_label,current(_id1),expected(_id)]),
  write(' INFORM CONCEPTBASE DEVELOPERS!'),nl,
  !.

checkCorrectID(_name,_label,_id) :-
  write('Literals.pro: '),write(_name),write('!'),write(_label),
  write(' does not (yet) exist! Some predicates may not work as expected.'),nl,
  !.


 






{ ********************* p r o v e _ l i t e r a l *************************** }
{                                                              MSt 12-Apr-89  }
{              prove_literal ( _lit )                                         }
{                       _lit : any : partial instantiated literal             }
{                                                                             }
{    checks wether literal _lit can be proven from                            }
{                a) PropositionBase/Inheritance/WeakDeduction                 }
{             or b) by LTruleEvaluator (only for AttrValue/InstanceOf/IsA )   }
{                                                                             }
{ *************************************************************************** }



{ "Dotted" A predicate replaces AttrValue in integrity constraints and
  triggered rules. The cc is the "concerned" class of the the original
  AttrValue. See also CBNEWS[152]}

{* #195: used only by SystemQueries.sml *}
prove_literal(AD(_cc,_x,_y)) :-
	var(_cc),
	!,
        (get_Adot(_cc,_x,_y,_);
         ded_Adot(_cc,_x,_y)).

prove_literal(AD(_cc,_x,_y)) :-
        ground(_cc),
        !,
        prove_literal(Adot(_cc,_x,_y)).



{Bei Anfrage-Auswertung, wenn prove_literal(Adot(_cc,_x,_ml,_y)) und _x oder _y nach einer Instanz von ExternalObject oder
 ExternalQuery referenziert ist, muessen alle Instanzen von der ggf. in CB eingeladen werden. Damit Auswertung fortfuehren kann.}
{* 2013-10-29/M.Jeusfeld: abandon ability to load external data
prove_literal(Adot(_cc,_x,_y)) :-
	LoadExternalDataForQueryEvaluating(yes),
	retrieve_proposition(P(_cc,_c,_ml,_d)),
	testIfShallLoad([_c,_d],_ObjToLoad),
	_ObjToLoad\==[],
	!,
	tell_temp_ExObj(_ObjToLoad),
	write('Instance for '),write(_ObjToLoad),write(' loaded!\n'),
  	!,
	prove_literal(Adot(_cc,_x,_y)).
}

prove_literal(Adot(id_1527,_x,_y)) :-   {* id_1527=Module!contains *}  {* see checkCorrectIDs *}
    !,
    retrieve_proposition_noimport(_x,P(_y,_,_,_)).

prove_literal(Adot(_cc,_x,_y)) :-
        get_Aedot(_cc,_x,_y).

{ If concerned class is the system class Attribute,
* then use get_Adot because these facts are not stored in the C-implemented object base. }
{* 18-Jan-2005/M.Jeusfeld: only consider Attribute, not the other system omega classes *}
{* and do not use prove_by_cache for this literal pattern!                             *}

{* if _x is a variable, then we cannot use prove_C_Attr_s *}
prove_literal(Adot(id_6,_x,_y)) :-   {* id_6=Attribute *}  {* see checkCorrectIDs *}
	var(_x),!,
        retrieve_proposition(P(_id,_x,_l,_y)),
        attribute(P(_id,_x,_l,_y)).


prove_literal(Adot(id_6,_x,_y)) :-   {* id_6=Attribute *}  {* see checkCorrectIDs *}
	!,
        prove_C_Attr_s(_x,_id),
        retrieve_proposition(P(_id,_x,_l,_y)).

prove_literal(Adot(_cc,_x,_y)) :-
	!,  { Keine weiteren Loesungen weiter unten relevant }
	ded_Adot(_cc,_x,_y).


{Bei Anfrage-Auswertung, wenn prove_literal(Adot_label(_cc,_x,_y,_l)) und _x oder _y nach einer Instanz von ExternalObject oder
 ExternalQuery referenziert ist, muessen alle Instanzen von der ggf. in CB eingeladen werden. Damit Auswertung fortfuehren kann.}
{* 2013-10-29/M.Jeusfeld: abandon ability to load external data
prove_literal(Adot_label(_cc,_x,_y,_l)) :-
	ground(_cc),
	LoadExternalDataForQueryEvaluating(yes),
	retrieve_proposition(P(_cc,_c,_ml,_d)),
	testIfShallLoad([_c,_d],_ObjToLoad),
	_ObjToLoad\==[],
	!,
	tell_temp_ExObj(_ObjToLoad),
	write('Instance for '),write(_ObjToLoad),write(' loaded!\n'),
  	!,
	prove_PROLOG_literal(Adot_label(_cc,_x,_y,_l)).
}
  {* was: Adot(.): _l was not bound! *}

{ Adot_label: Adot mit Attributlabel   11-Oct-96/CQ}
prove_literal(Adot_label(_cc,_x,_y,_l)) :-
	(var(_cc);systemOmegaClass(_cc)),
	!,
	prove_PROLOG_literal(Adot_label(_cc,_x,_y,_l)).

{* ticket #164: generalize the AL literal; do not use prove_C_Adot *}
{* since it does not allow to consider derived instantiations of   *}
{* attributes to attribute categories.                             *}

{* non-deduced solutions *}
prove_literal(Adot_label(_cc,_x,_y,_l)) :-
        get_Adot_label(_cc,_x,_y,_l).


{* solutions due to derived instantiations of attributes id to attribute categories cc *}
prove_literal(Adot_label(_cc,_x,_y,_l)) :-
        ground(_cc),var(_l),
        ded_In(_id,_cc),
        retrieve_proposition(P(_id,_x,_l,_y)).


prove_literal(Adot_label(_cc,_x,_y,_l)) :-
	ground(_cc),ground(_l),
	retrieve_proposition(P(_id,_x,_l,_y)),
	prove_In(_id,_cc).

{* 14-Nov-2007/M. Jeusfeld: support deduction on AL predicate; see ticket #164 *}
{* If AL is deducable, then the subsequent clause based on Adot is not used.   *}
prove_literal(Adot_label(_cc,_x,_y,_l)) :-
        ground(_cc),
	isDeducable(Adot_label(_cc,_x,_y,_l)),
	!,
        ded_Adot_label(_cc,_x,_y,_l).

prove_literal(Adot_label(_cc,_x,_y,_catom)) :-
	!,  { Keine weiteren Loesungen weiter unten relevant }
	ded_Adot(_cc,_x,_y),
        retrieve_proposition(P(_cc,_c,_ml,_d)),
	get_computed_atom(_ml,_y,_catom).


{* ticket #207: improve support for A_e *}
prove_literal(Aedot(_cc,_x,_y)) :-  
        get_Aedot(_cc,_x,_y).  { #195 }


{ A_label: A mit Label }
prove_literal(A_label(_x,_ml,_y,_l)) :-
	ground(_ml),!,
        retrieve_proposition(P(_id2,_c,_ml,_d)),
        attribute(P(_id2,_c,_ml,_d)),
        prove_In(_id1,_id2),
        retrieve_proposition(P(_id1,_x,_l,_y)),
        attribute(P(_id1,_x,_l,_y)).

prove_literal(A_label(_x,_ml,_y,_l)) :-
	retrieve_proposition(P(_id1,_x,_l,_y)),
	attribute(P(_id1,_x,_l,_y)),
	retrieve_proposition(P(_id2,_c,_ml,_d)),
	attribute(P(_id2,_c,_ml,_d)),
	prove_In(_id1,_id2).

prove_literal(A_label(_x,_ml,_y,_l)) :-
	ConcernedClass(A_label(_x,_ml,_y,_l),_cc),   {* ded_Adot_label requires _cc to be bound *}
        ded_Adot_label(_cc,_x,_y,_l).

prove_literal(A_label(_x,_ml,_y,_catom)) :-
	!,  { Keine weiteren Loesungen weiter unten relevant }
	ded_Adot(_cc,_x,_y),
	get_computed_atom(_ml,_y,_catom).



{Bei Anfrage-Auswertung, wenn prove_literal(In(_x,_c)) und _c eine Instanz von ExternalObject oder ExternalQuery ist,
muessen alle Instanzen von _c ggf. in CB eingeladen werden. Damit Auswertung fortfuehren kann.}
{* 2013-10-29/M.Jeusfeld: abandon ability to load external data
prove_literal(In(_x,_c)) :-
	LoadExternalDataForQueryEvaluating(yes),
	ground(_c),
	testIfShallLoad([_c],_ObjToLoad),
	_ObjToLoad\==[],
	!,
	tell_temp_ExObj(_ObjToLoad),
	write('Instance for '),write(_ObjToLoad),write(' loaded!\n'),
  	!,
 	prove_literal(In(_x,_c)).
}


prove_literal(In(_x,_c)) :-
  atom(_x),atom(_c),
  !,
  is_id(_x),  {* _x is really a ConceptBase object identifier *}
{*  pc_atomconcat('id_',_,_x),   *}
  prove_In(_x,_c),
  !.

{* 30-Jun-2004/M. Jeusfeld                                                   *}
{* Since now, ConceptBase also accepts parameterized query calls as          *}
{* parameters of other parameterized query calls. To do so, ConceptBase      *}
{* has to accept expressions like Q(y,....) as second argument of the        *}
{* literals In(x,c). The literal In(x,Q(y,..)) is true if x=y and Q(x,...)   *}
{* is true. Hence Q(y,...) is acting like class with instances being all     *}
{* y's for which Q(y,...) can be shown.                                      *}
{* See also CBNEWS.doc, point 215.                                           *}


prove_literal(In(_x,_querycall)) :-
  compound(_querycall),
  _querycall =..[_qid|[_x|_restargs]],
  !,
{*  write_lcall(In(_x,_querycall)),write(' mapped to '),write_lcall(_querycall),nl, *}
  prove_literal(_querycall).

prove_literal(In(_x,_c)) :-
  compound(_x),!,
  _x =.. [_id|_someargs],  {* x is a parameterized query call like id_123(...) *}
  prove_literal(In(_id,_c)).  {* reduce to check whether the query class itself has the class c *}


prove_literal(In(_x,_c)) :-
	!,
 	prove_In(_x,_c).


{ extensional "In" predicate, i.e., no user-defined deductive rules applied }
{ but instantiation to system classes plus inheritance is deduced:          }

prove_literal(In_e(_x,_c)) :-
  atom(_x),atom(_c),
  !,
  prove_In_e(_x,_c),
  !.

prove_literal(In_e(_x,_c)) :-
	!,  { Keine weiteren Loesungen weiter unten relevant }
  prove_In_e(_x,_c).

{ storage "In" predicate, i.e., only stored instantiation rel's: }

{prove_literal(In_s(_x,_c)) :-}
{	retrieve_proposition(P(_,_x,'*instanceof',_c)).}

prove_literal(In_s(_x,_c)):-
	!,  { Keine weiteren Loesungen weiter unten relevant }
	prove_C_In_s(_x,_c).


{ object "In" predicate, i.e., only instantiation to system classes: }

prove_literal(In_o(_x,_c)) :-
	!,  { Keine weiteren Loesungen weiter unten relevant }
  sys_In(_x,_c).

{ inheritance "In" predicate, i.e., only inherited instantiations to classes: }

{prove_literal(In_i(_x,_c)) :-}
{  IsA_axiom_1(In_i(_x,_c)).}

prove_literal(In_i(_x,_c)):-
	!,  { Keine weiteren Loesungen weiter unten relevant }
	prove_C_In_i(_x,_c).


{ beachtet die Vererbungsreihenfolge }
prove_literal(In_eh(_x,_c)) :-
  atom(_x),atom(_c),
  !,
  prove_In_eh(_x,_c),
  !.

prove_literal(In_eh(_x,_c)) :-
 	!,  { Keine weiteren Loesungen weiter unten relevant }
	prove_In_eh(_x,_c).



