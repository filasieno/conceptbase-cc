   var(_c),
   !,
   prove_by_cache(In(_x,_sub)),   {* this only evaluates the deductive rules for In(.,.)! *}
   (
   _c=_sub;   {* Ticket #145: _sub itself is also a class of _x! *}
   prove_literal(Isa_e(_sub,_c))
   ).

ded_In(_x,_c) :-
  atom(_c),
  prove_In_e(_c,id_104),   {* id_104=QueryCall; reified query calls: they can be re-evaluated *}
  id2name(_c,_cname),
  pc_atom_to_term(_cname,derive(_q,_slist)),
  replace_derive_expression('_',derive(_q,_slist),_qlit1),
  insertPROLOGVars(_qlit1,_qlit),
  !,
  prove_literal(In(_x,_qlit)).



