{ Wieder mal ein Hack. Known liefert die Erstellungs- }
{ zeit des IDs zurueck, die aber leider keinen ID hat. }
{ Daher wird hier ein Builtin-Objekt fuer den tt-String }
{ generiert, und davon wird dann der ID zurueckgegeben. }
{ Dadurch gibt es dann auch keine Folgefehler, da so    }
{ sichergestellt ist, dass ueberall IDs auftauchen. Jan-98/CQ}

prove_literal(Known(_id,_ttid)) :-
        var(_id),
        !,  { Keine weiteren Loesungen weiter unten relevant }
        retrieve_proposition(P(_id,_,_,_)),   {* bind to a known oid, one after the other *}
        id2starttime(_id,_tt),
        pc_atom_to_term(_ttatom,_tt),
        pc_atomconcat(['"',_ttatom,'"'],_ttstring),
        create_if_builtin_object(_ttstring,TransactionTime,_ttid).


prove_literal(Known(_id,_ttid)) :-
	!,  { Keine weiteren Loesungen weiter unten relevant }
        id2starttime(_id,_tt),
