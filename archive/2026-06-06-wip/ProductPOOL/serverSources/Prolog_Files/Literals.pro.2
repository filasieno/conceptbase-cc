{* In cachemode=keep, we empty the cache whenever the object base is *}
{* updated see procedures STORE and DELETE in FragmentToProposition  *}
{* and FragmentToHistoryProposition.                                 *}

checkToEmptyCacheOnUpdate :-
  getFlag(currentCacheMode,'off'),
  !.

checkToEmptyCacheOnUpdate :-
  getFlag(currentCacheMode,'keep'),
  CurrentUpdateMode(UPDATE),   {* only empty the cache when an UPDATE transaction is executed ee ticket #66 }
  getCacheSize(_n),
  _n > 0,
  setFlag(currentCacheMode,'off'),   {* an updating transaction may not see the cache at all *}
  WriteTrace('veryhigh',Literals,['Cache temporarily disabled during update']),
  erase_GRAPHTYPECANDIDATES,
  setCacheSizeExceeded,   {* 14-Oct-2004 *}
  !.

checkToEmptyCacheOnUpdate :-
  getFlag(currentCacheMode,_cm),
  _cm \== 'off',
  CurrentUpdateMode(UPDATE),   {* only empty the cache when an UPDATE transaction is executed ee ticket #66 }
  setFlag(currentCacheMode,'off'),
  erase_GRAPHTYPECANDIDATES,
  setCacheSizeExceeded,   {* 13-Nov-2007 *}
  WriteTrace('veryhigh',Literals,['Cache temporarily disabled during update']),
  !.

checkToEmptyCacheOnUpdate.  {* never fail *}


{* 1-Nov-2005: don't re-use caches containing stratification errors *}
{* no problem in 'transient' mode since in that mode, the cache is  *}
{* never re-used in subsequent transactions.                        *}

checkToEmptyCacheOnStratificationError :-
  getFlag(currentCacheMode,'keep'),
  getCacheSize(_n),
  _n > 0,
  erase_GRAPHTYPECANDIDATES,
  setCacheSizeExceeded,  {* will erase cache before next transaction *}
  !.

checkToEmptyCacheOnStratificationError.


{* used for 'keep' mode: if during an transaction an update (TELL/UNTELL) occurs  *}
{* we set the current cache size beyond the maximum. This will make sure that the *}
{* cache is emptied at the subsequent BEGIN_TRANSACTION. We shall not erase the   *}
{* cache on the fly because it would lead to inconsistent evaluations of          *}
{* prove_by_cache. See also remark in CBNEWS.doc[215].  14-Oct-2004/M.Jeusfeld    *}
setCacheSizeExceeded :-
  WriteTrace('veryhigh',Literals,['Will empty cache before next transaction']),
  get_cb_feature(maxCacheSize,_m),
  _m1 is _m+1,
  setCacheSize(_m1),
  !.



{* on this event we have to reset the currentCacheMode to its default and *}
{* empty the cache of certain conditions are true.                        *}
{* Called in CBserverInterface.pro at BEGIN_TRANSACTION                   *}

checkToEmptyCacheOnNewTransaction :-
  get_cb_feature(defaultCacheMode,keep),
  setCurrentToDefault(keep),
  getCacheSize(_n),
  get_cb_feature(maxCacheSize,_m),
  _n > _m,
  eraseCachedFacts('because maximum size exceeded or update or stratification error'),
  setCacheSize(0),
  !.
checkToEmptyCacheOnNewTransaction :-
  get_cb_feature(defaultCacheMode,transient),
  setCurrentToDefault(transient),
  eraseCachedFacts('to remove facts inserted by last transaction'),
  !.
checkToEmptyCacheOnNewTransaction :-
  get_cb_feature(defaultCacheMode,_m),
  setCurrentToDefault(_m).

checkToEmptyCacheOnSearchSpaceChange :-
  getFlag(currentCacheMode,_cm),
  (_cm='transient';_cm='keep'), 
  eraseCachedFacts('because of search space change'),
  !.

checkToEmptyCacheOnSearchSpaceChange.




{* 27-Oct-2003/M.Jeusfeld: an integrity test involving recursive rules can  *}
{* crash the server when executed with cache mode 'off'. However, the cache *}
{* mode must be 'off' during telling/untelling objects because the cache    *}
{* content becomes invalid when the object base changes. The procedure below *}
{* is used to re-enable the cache as soon as possible, i.e. just after the  *}
{* object base has been updated. See also ObjectProcessor.pro               *}

checkToEnableCacheAfterUpdate :-
  getFlag(currentCacheMode,'off'),    {* this is set to 'off' during an UPDATE transaction *}
  get_cb_feature(defaultCacheMode,_dm),    {* this is usually 'transient' or 'keep' *}
  _dm \== 'off',
  setFlag(currentCacheMode,_dm),     {* set to default cache mode to allow crash-free integrity test *}
  precompute_DEDUCABLE,              {* refresh the precomputed IS_DEDUCABLE facts *}
  WriteTrace('veryhigh',Literals,['Cache mode re-set to ',_dm,' after object base update']),
  !.

checkToEnableCacheAfterUpdate.



{* FragmentToPropositions and FragmentToHistoryPropositions need to evaluate a few *}
{* literals, e.g. in find_attributeclasses, during the update. The literals could  *}
{* be recursively defined. Hence, we re-enable the cache for such literal          *}
{* literal evaluations. See also prove_upd_literal and ticket #126.                *}

checkToEnableCacheDuringUpdate :-
  getFlag(currentCacheMode,'off'),    {* this is set to 'off' during an UPDATE transaction *}
  get_cb_feature(defaultCacheMode,_dm),    {* this is usually 'transient' or 'keep' *}
  _dm \== 'off',
  setFlag(currentCacheMode,_dm),     {* set to default cache mode to allow crash-free integrity test *}
  precompute_DEDUCABLE,              {* refresh the precomputed IS_DEDUCABLE facts *}
{*  WriteTrace('veryhigh',Literals,['Cache mode set to ',_dm,' during object base update']), *}
  !.

checkToEnableCacheDuringUpdate.





{* erase facts generated for GraphEditor; see also OB.builtin and GeneralUtilities.pro *}
erase_GRAPHTYPECANDIDATES :-
  pc_erase_all(GRAPHTYPECANDIDATES),
  !.
erase_GRAPHTYPECANDIDATES. {* never fail *}




setCurrentToDefault(_default) :-
  getFlag(currentCacheMode,_default),  {* is already default *}
  !.

setCurrentToDefault(_default) :-
  setFlag(currentCacheMode,_default),
  WriteTrace('veryhigh',Literals,['Cache mode reset to ',_default]),
  !.

setCacheModeDefault :-
  get_cb_feature(defaultCacheMode,_m),
  setCurrentToDefault(_m).



eraseCachedFacts(_why) :-
  printCacheStatistics(_why),   {* not essential for CB *}
  pc_recorded('CachePredicate',_prednames),
  pc_member(_predname,_prednames),   {* need to scan erase all cache slots for _predname *}
  eraseCallStates(_predname),
  pc_erase_all(_predname),
  fail.

eraseCachedFacts(_) :-
  pc_erase_all(CachePredicate),   {* this also has to go *}
  pc_erase_all(READSDIRTYFROM),   {* erase the dirty read dependencies *}
  pc_erase_all(SUBSUMEDBY),   {* erase the subsumption dependencies *}
  pc_erase_all(EMPTYNESSOBLIGATIONS),   {* erase the emptyness obligations *}
  deleteAskQueryBuffers,   {* filled in AnswerTransformUtilities.pro *}
{*  WriteOnTrace('low','%%% Cache cleared again -- '), WriteNewlineOnTrace('low'), *}
  !.

eraseCachedFacts(_).  {* nothing cached? also succeed with erasing *}


eraseCallStates(_predname) :-
  pc_current_key(_argkey,_predname),
  pc_erase_all(_argkey),   {* erase call states *}
  fail.
eraseCallStates(_).




{* This is just for displaying some statistics about the *}
{* cache size. Will only be displayed if trace mode is   *}
{* set to 'high' or beyond.                              *}
{* Will slow down performance a bit.                     *}

printCacheStatistics(_why) :-
  get_cb_feature(TraceMode,_tracemode),
  conforms(veryhigh,_tracemode),   {* print statistics if tracemode=xxx or higher *}
  !,
  pc_record('NPREDS',0),
  pc_record('SIZE',0),
  pc_record('EMPTY',0),
  pc_record('completed',0),
  pc_record('dirty',0),
  pc_record('pending',0),
  pc_record('incomplete',0),
  pc_record('recursive',0),
  getCacheSlots(_npreds,_size,_empty,_comp,_dirty,_pend,_incomp,_ree),
  !,
  printThem(_npreds,_size,_empty,_comp,_dirty,_pend,_incomp,_ree,_why),
  pc_erase('NPREDS'),
  pc_erase('SIZE'),
  pc_erase('EMPTY'),
  pc_erase('completed'),
  pc_erase('dirty'),
  pc_erase('pending'),
  pc_erase('incomplete'),
  pc_erase('recursive'),
  !.



printCacheStatistics(_why).


printThem(0,_,_,_,_,_,_,_,_why) :-
{*  !,
  write('%%% Cache is already empty '),nl, *}
  !.

printThem(_npreds,_size,_empty,_comp,_dirty,_pend,_incomp,_ree,_why) :-
  (_why='stopCBserver';
    write('%%% Cache to be cleared '),write(_why),nl
  ),
  write('%%% Number of cache slots:        '),write(_npreds),
  write(' ('),
  write(_comp),write(' completed, '),
  write(_dirty),write(' dirty, '),
  write(_pend),write(' pending, '),
  write(_incomp),write(' incomplete, '),
  write(_ree),write(' recursive)'),
  nl,
  write('%%% Total number of stored facts: '),write(_size),nl,
  write('%%% Number of empty cache slots:  '),write(_empty),nl,
{*  write('%%% (c) 2002-2009 ConceptBase Magic Cache Evaluator by M. Jeusfeld (jeusfeld@uvt.nl)'),*}
  nl,nl, 
  !.


getCacheSlots(_npreds,_size,_empty,_comp,_dirty,_pend,_incomp,_ree) :-
  pc_recorded('CachePredicate',_prednames),
  pc_member(_predname,_prednames),
  save_setof(_argkey, pc_current_key(_argkey,_predname),_argkeys),   {* 12-Jul-2005: retrieve argkeys from cache slots *}
  incrementNPREDS(_argkeys),
  computeSizeEmpty(_predname,_argkeys),
  fail.

getCacheSlots(_npreds,_size,_empty,_comp,_dirty,_pend,_incomp,_ree) :-
  pc_recorded('NPREDS',_npreds),
  pc_recorded('SIZE',_size),
  pc_recorded('EMPTY',_empty),
  pc_recorded('completed',_comp),
  pc_recorded('dirty',_dirty),
  pc_recorded('pending',_pend),
  pc_recorded('incomplete',_incomp),
  pc_recorded('recursive',_ree).




incrementNPREDS(_list) :-
  length(_list,_delta),
  pc_recorded('NPREDS',_npreds),
  _npreds1 is _npreds + _delta,
  pc_rerecord('NPREDS',_npreds1).

computeSizeEmpty(_predname,[]) :- !.

computeSizeEmpty(_predname,_argkeys) :-
  pc_member(_argkey,_argkeys),
  getCacheContent( (_argkey,_predname), _state, _lits),
  incrementSIZE(_lits),
  incrementEMPTY(_lits),
  incrementNrState(_state),
  fail.

computeSizeEmpty(_,_).

incrementSIZE(_lits) :-
  pc_recorded('SIZE',_size),
  lengthWithoutSync(_lits,_len),
  _size1 is _size + _len,
  pc_rerecord('SIZE',_size1),
  !.

lengthWithoutSync([],0) :- !.

lengthWithoutSync([sync|_rest],_len) :-
  !,
  lengthWithoutSync(_rest,_len).

lengthWithoutSync([_x|_rest],_len) :-
  lengthWithoutSync(_rest,_len1),
  _len is _len1 + 1 .



incrementEMPTY(_l) :-
  (_l = []; _l = [sync]),
  !,
  pc_recorded('EMPTY',_empty),
  _empty1 is _empty + 1,
  pc_rerecord('EMPTY',_empty1).

incrementEMPTY(_).

incrementNrState(_state) :-
  !,
  pc_recorded(_state,_nr),
  _nr1 is _nr + 1,
  pc_rerecord(_state,_nr1).

incrementNrState(_).


incrementCacheSize :-
  getFlag(currentCacheMode,'keep'),
  pc_recorded(currentCacheSize,'COUNTER',_s),
  _s1 is _s + 1,
  pc_rerecord(currentCacheSize,'COUNTER',_s1),
  !.
incrementCacheSize.

getCacheSize(_n) :-
   pc_recorded(currentCacheSize,'COUNTER',_n).

setCacheSize(_n) :-
  pc_rerecord(currentCacheSize,'COUNTER',_n).




{* evalFunctionArg                                                      *}
{*  - evaluates the arguments of a function                             *}
{* to be used in SYSTEM.builtin for builtin Functions like PLUS         *}


{* case 1: nothing to evaluate, arg is already an object *}
evalFunctionArg(_arg,_arg) :- atom(_arg),!.

{* case 2: we need to evaluate a query call *}
evalFunctionArg(_call,_value) :-
  compound(_call),
  _call =.. [_qid|[_value|_restargs]],
  evalFunctionArgs(_restargs,_evaluatedargs),  {* args may be function calls as well; ticket #175 *}
  _newcall =.. [_qid|[_value|_evaluatedargs]],
  is_id(_qid),  {* is a query call *}
  evalFunctionCall(_newcall,_qid,[_value|_evaluatedargs]), {* only take the first solution! *}
{*  prove_literal(_newcall), <--- equivalent generic evaluation via prove_literal *}
  !.



{* Evaluate args if f(args) before f(args) is evaluated     *}
{* This is the classical evaluation strategy for functional *}
{* expressions.                                             *}
evalFunctionArgs([],[]) :- !.

evalFunctionArgs([_arg|_rest],[_val|_restvals]) :-
  tryEvalFunctionArg(_arg,_val),  {* dependent of type of _arg *}
  evalFunctionArgs(_rest,_restvals).


{* the arguments of a functional expression may either be function calls,
   values (object ids), or query calls. In the latter case, we may not
   evaluate the query calls but only their arguments. The situation occurs
   when evaluating queries like
     IPLUS(COUNT(Q[x,y]),2)
   Here, the query Q[x,y] may not be evaluated. Rather, we may only evaluate
   the arguments x,y and then the outer call COUNT(.).
   This repairs an incompleteness introduced by the genereral admission of
   functional expressions in ticket #175.
*}
tryEvalFunctionArg(_arg,_arg) :- atom(_arg),!.

tryEvalFunctionArg(_call,_newcall) :-
   compound(_call),
   _call =.. [_qid|[_value|_args]],
   is_id(_qid),
   _Function=id_106,  {* instead name2id('Function',_Function) *}
   decideOnFunction(_call,_qid,_value,_args,_Function,_newcall).

{* case 1: the call is a function call *}
decideOnFunction(_call,_qid,_value,_args,_Function,_newcall) :-
   prove_edb_literal(In_e(_qid,_Function)),
   !,
   evalFunctionArg(_call,_newcall).

{* case 2: call is a regular complex query call *}
decideOnFunction(_call,_qid,_value,_args,_Function,_newcall) :-
   evalFunctionArgs(_args,_evaluatedargs),  {* args may have to be evaluated *}
   _newcall =.. [_qid|[_value|_evaluatedargs]],
   !.
   





