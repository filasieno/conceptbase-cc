  checkCorrectID(Proposition,id_0),
  checkCorrectID(QueryClass,id_65),
  checkCorrectID(QueryCall,id_104),
  checkCorrectID(Attribute,id_6),
  checkCorrectID(Individual,id_7),
  checkCorrectID(InstanceOf,id_1),
  checkCorrectID(IsA,id_15),
  checkCorrectID(Function,id_106),
