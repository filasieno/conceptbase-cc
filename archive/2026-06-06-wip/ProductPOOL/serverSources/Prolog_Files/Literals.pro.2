{* ... now following arithmetic comparisons (a la FORTRAN)   *}
{* 22-Mar-1989/MJf                                           *}

{* 26-Jan-2005/M.Jeusfeld: allow functional expressions as   *}
{* arguments of comparison literals (see ticket #46 and      *}
{* CBNEWS[215]). The functional expressions are generated    *}
{* in MSFOLassertionParserUtilities. See treatment of        *}
{* comparison literals there. The idea is quite simple: a    *}
{* functional expressions (COUNT,PLUS,...) is first evaluated*}
{* and then the comparison literal is executed.              *}

prove_literal(LT(_expr1,_expr2)) :-
    evalFunctionArg(_expr1,_tid1),
    evalFunctionArg(_expr2,_tid2),
    id2term(_tid1,_t1),
    id2term(_tid2,_t2),
    !,
    _t1 @< _t2.

prove_literal(GT(_expr1,_expr2)) :-
    evalFunctionArg(_expr1,_tid1),
    evalFunctionArg(_expr2,_tid2),
    id2term(_tid1,_t1),
    id2term(_tid2,_t2),
    !,
    _t1 @> _t2.

prove_literal(LE(_expr1,_expr2)) :-
    evalFunctionArg(_expr1,_tid1),
    evalFunctionArg(_expr2,_tid2),
    id2term(_tid1,_t1),
    id2term(_tid2,_t2),
    !,
    _t1 @=< _t2.

prove_literal(GE(_expr1,_expr2)) :-
    evalFunctionArg(_expr1,_tid1),
    evalFunctionArg(_expr2,_tid2),
    id2term(_tid1,_t1),
    id2term(_tid2,_t2),
    !,
    _t1 @>= _t2.


{* ticket #142: the first 3 clauses allow EQ to bind values             *}
{* to variables.  Hence, EQ is more powerful than IDENTICAL and UNIFIES *}


prove_literal(EQ(_x,_y)) :-
    (var(_x), var(_y);
     atom(_x),atom(_y);
     atom(_x), var(_y);
     var(_x), atom(_y)
    ),
    !,
    _x = _y.

prove_literal(EQ(_var1,_expr2)) :-
    var(_var1),
    !,
    evalFunctionArg(_expr2,_tid2),
    _var1=_tid2.

prove_literal(EQ(_expr1,_var2)) :-
    var(_var2),
    !,
    evalFunctionArg(_expr1,_tid1),
    _var2=_tid1.

{* Ticket #157: if x,y are both object identifiers, then we may not regard them as *}
{* functional expressions and apply id2term. We just check whether x and y are     *}
{* identical.                                                                      *}
{*
prove_literal(EQ(_x,_y)) :-
    is_id(_x),
    is_id(_y),
