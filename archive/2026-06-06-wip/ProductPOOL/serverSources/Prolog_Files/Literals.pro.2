#MODE( id2term(i,o))


id2term(_tid,tt(millisecond(_y,_m,_d,_h,_min,_sec,_msec))) :-
	id2name(_tid,_ttstring),
	pc_atomconcat('"',_ttrest,_ttstring),
	pc_atomconcat(_tt,'"',_ttrest),
	pc_atom_to_term(_tt,tt(millisecond(_y,_m,_d,_h,_min,_sec,_msec))),
	!.

id2term(_id,_term) :-
	id2name(_id,_x),
	pc_atom_to_term(_x,_term),
        nonvar(_term),  {* some Telos object names like ZERO shall not be transferred to a variable! Ticket #88 *}
	!.

id2term(_id,_name) :-
	id2name(_id,_name),
	!.

id2term(_id,_id).



{* ************************************************************************* *}
{* transform_querycall(_queryname,_thisname,_substlist,_querylit)            *}
{*   queryname: label of a query (atom)                                      *}
{*   thisname:  placeholder for the answer object ~this (free or atom)       *}
{*   substlist: list of substitutions (partial)                              *}
{*   querylit: resulting query literal executable by prove_literal           *}
{*                                                                           *}
{* The external object names in queryname, thisname, and substlist are       *}
{* replaced by the corresponding object identifiers. Then, the querylit is   *}
{* created from the substlist and the query's signature QueryArgExp.         *}
{* Note that querylits have the format                                       *}
{*    id_q(_this,_a1,_a2,...)                                                *}
{* where _this is the answer object and a1,... are the parameters (or        *}
{* retrieved/computed attributes.                                            *}
{* We currently only support queries with parameters, not retrieved or       *}
{* computed attributes.                                                      *}
{* ************************************************************************* *}

transform_querycall(_queryname,_thisname,_substlist,_querylit) :-
  transformQueryname(_queryname,_qid),
  transformVar(_thisname,_this),
  transformSubstlist(_substlist,_substlist_id),
  create_querylit(_qid,_this,_substlist_id,_querylit),
  !.

transformQueryname(_queryname,_qid) :- name2id(_queryname,_qid).

transformVar(_v,_v) :- var(_v),!.
transformVar(_name,_id) :-  name2id(_name,_id).

transformSubstlist([],[]) :- !.

transformSubstlist([_val/_label|_rest],[substitute(_id,_label)|_rest_res]) :-
  transformVar(_val,_id),
  transformSubstlist(_rest,_rest_res).



create_querylit(_qid,_answer,_subst_list,_query_lit) :-
  QueryArgExp(_qid,[this|_param_defs]),
  generateQueryArgs(_param_defs,_subst_list,[],_args),
  append([_qid,_answer],_args,_call_as_list),
  _query_lit =.. _call_as_list,
  !.

generateQueryArgs([],_,_so_far,_so_far).

generateQueryArgs([p(_label,_cid)|_rest_params],_subst_list,_so_far,_args) :-
  getQueryArg(_label,_subst_list,_arg),
  append(_so_far,[_arg,_cid],_new_so_far),
  generateQueryArgs(_rest_params,_subst_list,_new_so_far,_args).


getQueryArg(_label,[substitute(_arg,_label)|_],_arg) :-
  !.

getQueryArg(_label,[_|_rest],_arg) :-
  getQueryArg(_label,_rest,_arg).






{* -------------------------------------------------------------------------- *}
{*                                                                            *}
{* The Magic Cache Machine for evaluation of recursive predicates             *}
{* By Manfred Jeusfeld, Tilburg University, February 2002                     *}
{*                                                                            *}
{* Originally, the magic cache machine featured the trick to answer cyclic    *}
{* literal calls that occur during the evaluation of a litral with the same   *}
{* argument structure via a cache (containing the solutions for this literal  *}
{* computed so far.                                                           *}
{* This trick prevents endless loops but per se does not compute the complete *}
{* extension of the literal. Hence, Christoph has devised a backtracking      *}
{* mechnism which resulted in a better approximation of the complete extension*}
{* but it wasn't complete in all cases.                                       *}
{*                                                                            *}
{* 8-Aug-2002: I now have revised the literal computation to compute the      *}
{* extension with a fixpoint iteration. While the execution is formally top-  *}
{* down (Prolog), the fixpoint is essentially computed bottom-up, i.e. it     *}
{* starts with immidiate consequences, then one execution of a recursive rule,*}
{* then two, etc.                                                             *}
{* To understand the execution, one has to keep in mind that prove_by_cache   *}
{* is only called for literals that are potentially defined by rules. The     *}
{* test 'isDeducable' further limits the evaluation to those literals which   *}
{* are indeed defined by a (user-defined) rule.                               *}
{* The basic idea behind the literal evaluator is as follows:                 *}
{*   - the start is a fresh literal call                                      *}
{*   - this is channelled to iterate_save_prove_explicit                      *}
{*   - then the state of this literal call (identified by its argument signa- *}
{*     ture is set to 'pending'                                               *}
{*   - iterate_save_prove_explicit proves all facts (extension) of the literal*}
{*     call one after the other via backtracking; each proven fact is stored  *}
{*     in its cache                                                           *}
{*   - save_prove will first compute the complete extension of _lit and then  *}
{*     the call from its cache                                                *}
{*   - all cyclic recursive calls occuring during the evaluation of our       *}
{*     literal are answered from cache (save_prove_with_state)                *}
{*  -  iterate_save_prove_explicit has three possible states after the call   *}
{*     try_prove_and_store:                                                   *}
{*      (1) a new fact has been found: succeed iterate_save_prove, i.e. return*}
{*          the new fact to QueryEvaluator                                    *}
{*      (2) no new fact but the current interation (repeat) had delivered at  *}
{*          least one new fact: fail in order to start a new iteration which  *}
{*          redoes the literal evaluation with the updated cache              *}
{*      (3) no new fact and the current iteration has delivered no fact at    *}
{*          all: finally fail iterate_save_prove, i.e. the extension has been *}
{*          completed                                                         *}
{*                                                                            *}
{* At a given point of time the cache for a literal call lit has the structure*}
{*   [lit7,lit6,sync,lit5,lit4,lit3,sync,lit2,lit1,sync]                      *}
{* The sync separates the facts computed in one execution of an iteration. So,*}
{* here we have 3 iterations where the last entry lit7 is at the head of the  *}
{* list.                                                                      *}
{*                                                                            *}
{* 29-Aug-2002/MJf: Another major revision to remove an incompleteess in the  *}
{* computation of the fixpoint.                                               *}
{* The fixpoint iteration of the original iterate_save_prove_explicit was     *}
{* incomplete. Consider the rules:                                            *}
{*   lit1(x) :- rel(x).                                                       *}
{*   lit1(x) :- rel2(x,y),lit2(y).                                            *}
{*   lit2(x) :- lit1(x).                                                      *}
{* Let lit1(x) be a call. Then it is evaluated and will reach a call lit2(y)  *}
{* which will again call lit1(y) which is then answered from the cache of lit1*}
{* since lit1 is in the call path. Since lit1 is not yet completely evaluated *}
{* the cache of lit1 will be incomplete. Hence, the solutions to the call of  *}
{* lit2 will also be incomplete.                                              *}
{* The old version of the fixpoint operator did not cover this case. The      *}
{* new version introduces two new call states:                                *}
{*   dirty: this call was computed by using some incomplete cache (e.g. lit2) *}
{*   incomplete: this cache is known to be incomplete (e.g. lit1)             *}
{* The 'dirty calls' are made re-entrant, i.e. when they are called a 2nd     *}
{* time, they will be explicitely evaluated (not answered from their cache).  *}
{* The 'incomplete' calls are subject to further iteration (monster_iterate)  *}
{* Their cache is not 'dirty' but has to be extended. The re-entrant calls to *}
{* the dirty literals will 'see' more and more facts in the cache of the      *}
{* incomplete call. There is only one 'incomplete' call (lit1) which controls *}
{* the loop in monster_iterate, but all 'newer' call in the call path from    *}
{* lit1 are potentially dirty when they read the cache of lit1.               *}
{* When a call is marked incomplete, it will remain in monster_iterate until  *}
{* it is 'complete'. Hence, 'incomplete' calls never become 'dirty'. Otherwise*}
{* infinite loops would occur.                                                *}
{* After each iteration of monster_iterate, the system checks whether a new   *}
{* fact was added to the cache of lit1 or whether its state is still the      *}
{* original state 'pending'. In both cases, the monster_iteration can be      *}
{* stopped. Otherwise, we loop.                                               *}
{* The old iterate_save_prove_explicit is still there. It will iterarate a    *}
{* call lit until it cannot find more facts (given the current extensions of  *}
{* caches.                                                                    *}
{*                                                                            *}
{* 7-Oct-2005/M.Jeusfeld: On Stratification (Ticket #79)                      *}
{* The old stratification test was generating wrong stratification messages   *}
{* (e.g. query DeadEndCity in BigFlights.sml) and also missed to detect       *}
{* some stratification violations (ShavedByBarber in Barber.sml).             *}
{* This has now bveen solved by just testing two cases for stratification     *}
{* violation:                                                                 *}
{*                                                                            *}
{*  STRATIFICATION_VIOLATION1:                                                *}
{*    A recursive call to a negated predicate -P(a) occurs at a time when the *}
{*    the call is not yet fully evaluated and has currently an empty          *}
{*    cache (=extension). Then, the system assumes that 'not P(a)'  is true   *}
{*    and (possibly) derives some conclusions based on it. If later during    *}
{*    the evaluation the predicate P(a) is proven to be true, i.e. the cache  *}
{*    of -P(a) gets an entry, then we have based our computation on both      *}
{*      P(a) and not P(a)                                                     *}
{*    This is of course a (dynamic) stratification violation.                 *}
{*                                                                            *}
{*  STRATIFICATION_VIOLATION2:                                                *}
{*    A positive call P(a,x) is being evaluated with at least one variable.   *}
{*    During this call a matching negative call -P(a,b) is being evaluated    *}
{*    yielding that P(a,b) is true (hence not P(a,b) is false). When the      *}
{*    original call P(a,x) is completed, then x=b does not show up in its     *}
{*    extension. Hence, the computation again relied on both                  *}
{*      P(a,b) and not P(x,b)                                                 *}
{*    This is the second type of stratification violation by a subsuming call.*}
{*                                                                            *}
{* -------------------------------------------------------------------------- *}

prove_by_cache(_lit) :-
  effectiveCacheMode(_mode),   {* ticket #237 *}
  prove_by_cache(relational,_mode,_lit).   {* relational: can deliver multiple answers *}


prove_function_by_cache(_lit) :-
  effectiveCacheMode(_mode),   {* ticket #237 *}
  prove_by_cache(functional,_mode,_lit).  {* functional: delivers at most one answer *}


{* mode=off: cache may not be used *}
{* _lit is a query call with other query call as paraneter: cache may not be used *}
prove_by_cache(_card,_mode,_lit) :-
  (_mode == off;
  isComplexQlit(_lit)),
  !,
  isDeducable(_lit),   {* _lit is in fact deducable by rules *}
  prove_explicit(_lit).    {* ==> prove _lit without the cache *}

{* otherwise the cache is utilized: *}
prove_by_cache(_card,_,_lit) :-
  isDeducable(_lit),   {* _lit is in fact deducable by rules *}
  getAbstractCall(_lit,_cacheSlotId,_clit),   {* _clit is the representation of _lit used for the cache *}
  definePred(_lit,_cacheSlotId),
{* write('About to save_prove: '),write_lcall(_lit),nl, *}
  !,
  save_prove(_card,_lit,_clit,_cacheSlotId).








{* first compute complete extension of _lit *}
save_prove(_card,_lit,_clit,_cacheSlotId) :-
  welcome_fresh_call(_cacheSlotId),
  monster_iterate_prove_explicit(_card,_lit,_clit,_cacheSlotId). {* this will ultimately fail! *}


{* Then serve the call _lit from the cache *}
{* This case will also be followed when welcome_fresh_call fails *}
save_prove(relational,_lit,_clit,_cacheSlotId) :-
  getFromCache(_clit,_cacheSlotId).

save_prove(functional,_lit,_clit,_cacheSlotId) :-
  getFromCache(_clit,_cacheSlotId),
  !.


{* If a predicate of an ECArule condition is evaluated against the old database state, *}
{* then we can still employ the cache since the updates of the current transaction     *}
{* incl. updates of ECA actions) are anyway not visible.                               *}
{* Regular ASK queries are evaluated with searchspace=(newOB,Now) (see                 *}
{* ObjectProcessor.pro). So, the first clause is only applicable when predicates       *}
{* of an ECArule condition are evaluated against the old database state (oldOB,Now).   *}
{* See ticket #237.                                                                    *}

effectiveCacheMode(enabledForECA) :-
  get_KBsearchSpace(oldOB,Now),
  get_cb_feature(defaultCacheMode,_defmode),
  _defmode \== off,
  !.

effectiveCacheMode(_mode) :-
  getFlag(currentCacheMode,_mode).




{* a call is welcome for a new evaluation if it was either not called before *}
{* or it has dirty state. In the latter case, we reset it to pending just    *}
{* to have a chance to go to 'completed'                                     *}

welcome_fresh_call(_cacheSlotId) :-
  getCallState(_cacheSlotId,_state), 
  !,
  do_welcome_fresh_call(_cacheSlotId,_state).

{* _cacheSlotId has no state, i.e. called for the first time *}
welcome_fresh_call(_cacheSlotId) :- 
  initCallState(_cacheSlotId),    {* sets state to pending and initializes the cache *}
{*  writeCacheSlot(_cacheSlotId),write(' called'),nl, *}
  pushActiveCall(_cacheSlotId), 
  !.

{* re-enter a 'pending' call, see ticket #179                                 *}
{* The re-entry will be rejected if _cacheSlotId is an active call, i.e.      *}
{* on the current call stack. Such cases indicate a recursive call. The       *}
{* procedure pushActiveCall(_cacheSlotId) will block such attempts and set    *}
{* the calls state to 'recursive'. This is one of the ingredients to the      *}
{* solution of ticket #213.                                                   *}
{* If _cacheSlotId is not on the current call stack, then we can happily      *}
{* evaluate the call. This is necessary for the case of ticket #179: not      *}
{* all cache slots are completed during a query evaluation. They may be called*}
{* a again for a subsequent query evaluation. Then, we need to complete the   *}
{* pending call.                                                              *}

do_welcome_fresh_call(_cacheSlotId,'pending') :-
{*  writeCacheSlot(_cacheSlotId),write(' called again'),nl,  *}
  pushActiveCall(_cacheSlotId),   {* will fail if _cacheSlotId is on the current call stack! *}
  !.


do_welcome_fresh_call(_cacheSlotId,'dirty') :-
  isWritten(_somecache),   {* only re-enter a 'dirty' call when some cache was updated in the previous iteration *}
  (
    (_cacheSlotId=_somecache);                  {* predicate whose cache is written is called again     *}
    readsDirtyFrom(_cacheSlotId,_somecache);    {* this predicate has a chance to deliver new solutions *}
    dirtyFromIncomplete(_cacheSlotId)           {* current call path is not yet completed; ticket #286  *}
  ),
  setCallState(_cacheSlotId,'pending'),        {* not sure whether this is actually necessary *}
  pushActiveCall(_cacheSlotId),
  !.


{* only for tracing ...
do_welcome_fresh_call(_cacheSlotId,'dirty') :-
  getCallState(_cacheSlotId,'dirty'),
  isWritten(_somecache),
  write(_cacheSlotId),write(' did not pass as fresh call even though '),
  write(_somecache), write(' was written.'),nl,
  !,
  fail.
*}



{* monster_iterate is the main innovation in the renovation of the     *}
{* Magic Cache Evaluator done in August 2002. It had to be intro-      *}
{* duced because of the effect of 'dirty reads' (see below). Such      *}
{* dirty reads prevent that the complete extension of a predicate      *}
{* can be computed just by the inner iteration iterate_prove_explicit. *}
{* We leave this monster iteration when either the call state of       *}
{* this call _lit is not incomplete (monster iterations only occur     *}
{* on incomplete calls!) or no fact has been added into any            *}
{* cache in the current monster iteration.                             *}

{* the cardinality _card of the result set can be 'functional' (at     *}
{* most one element in the result set) or 'relational' (any number of  *}
{* elements in the result set. By this, we make sure that only the     *}
{* first answer is relevant for function calls.                        *}

monster_iterate_prove_explicit(_card,_lit,_clit,_cacheSlotId) :-
 (_clit == 't'; _card == functional),
 prove_once_and_store(_lit,_clit,_cacheSlotId),
 popActiveCall,
 !,
 fail.


monster_iterate_prove_explicit(relational,_lit,_clit,_cacheSlotId) :-
 repeat,
   iterate_prove_explicit(_lit,_clit,_cacheSlotId),
 exitOrLoop(_cacheSlotId),
 !,
 fail.  {* will then force the save_prove to return the solution of the call _lit via its cache *}


exitOrLoop(_cacheSlotId) :-
  getCallState(_cacheSlotId,_state),
  exitOrLoop(_cacheSlotId,_state).


{* the cache of this call got a dirty read *}
exitOrLoop(_cacheSlotId,'incomplete') :-
  pc_recorded(CACHEWRITTEN,_cacheB),  {* oops, and the cache was updated *}
  pc_erase(CACHEWRITTEN),          {* init for next loop of monster_iterate *}
  !,
  fail.



exitOrLoop(_cacheSlotId,_state) :-
  pc_erase(CACHEWRITTEN),          {* init in any case (24-May-2004/M.Jeusfeld) *}
  transCallState(_cacheSlotId,_state,'NoMoreFacts'),   {* this incomplete call is now completed     *}
  setDirtyReadersToPending(_cacheSlotId),              {* its dirty readers are then pending        *}
  popActiveCall.


writeCallPath(_prefix) :-
  pc_recorded(ACTIVE,'LIST',_calls),
  _calls \= [],
  write(_prefix),nl,
  do_writeCallPath(_calls),
  nl,
  !.
writeCallPath(_).  {* continue even if no active calles defined *}


do_writeCallPath([]) :- !.

do_writeCallPath([_cacheSlotId|_calls]) :-
  do_writeCallPath(_calls),
  _cacheSlotId = (_argkey,_predname),
  getCacheContent(_cacheSlotId,_state,_content),
  write(' ('),writeState(_state),write(') '),
  writeCacheSlot(_cacheSlotId),
  write('='),write_lcall(_content),nl,
  !.

writeState('recursive') :- write('R'),!.
writeState('pending') :- write('P'),!.
writeState('incomplete') :- write('I'),!.
writeState('completed') :- write('C'),!.
writeState('dirty') :- write('D'),!.
writeState(_) :- write('?').


{* A call path is incomplete if it contains a call with state=incomplete *}
{* This indicates that we still are not finished with the computation.   *}
{* We check whether the _newcall reads dirty from an incomplete call.    *}
{* In such cases, a predicate call that has state=dirty is allowed to    *}
{* re-enter via welcome_fresh_call. Ticket #286.                         *} 

dirtyFromIncomplete(_newcall) :-
  _newcall = (_ca,_cp),
  pc_atomconcat(_ca,_cp,_newcallId),
  pc_recorded(ACTIVE,'LIST',_calls),
  checkDirtyFromIncomplete(_newcallId,_calls).


{* we arrived at the incomplete call on the stack *}
checkDirtyFromIncomplete(_newcallId,[_call|_]) :-
  getCallState(_call,'incomplete'),
  readsDirtyFrom_Atom(_newcallId,_call),
  !.

checkDirtyFromIncomplete(_newcall,[_call|_rest]) :-
  checkDirtyFromIncomplete(_newcall,_rest).





{* pushActiveCall adss a new call _cacheSlotId to the stack of ACTIVE calls *}
{* At a given time, the stack has the form                                        *}
{*   [call5,call4,call3,call2,call1]                                              *}
{* where call5 is the most recent call.                                           *}
{* All calls in the stack are still under evaluation.                             *}
{* pushActiveCall prevents that a recursive call is entered. This was previously  *}
{* controlled by the callstate (pending,...) of the call. But since we introduced *}
{* the new state 'dirty', some of the existing calls are in principle re-entrant. *}

pushActiveCall(_cacheSlotId) :-
  pc_recorded(ACTIVE,'LIST',_calls),
  !,
  addActiveCall(_cacheSlotId,_calls).

pushActiveCall(_cacheSlotId) :-
  pc_record(ACTIVE,'LIST',[_cacheSlotId]),
{*  writeCallPath('0 Call Path: '),  *}
  !.

addActiveCall(_cacheSlotId,_calls) :-
  memberchk(_cacheSlotId,_calls),
{*  writeCacheSlot(_cacheSlotId),write(' is recursive'),nl,   *}
  setCallState(_cacheSlotId,'recursive'),    
  !,fail.



addActiveCall(_cacheSlotId,_calls) :-
  pc_rerecord(ACTIVE,'LIST',[_cacheSlotId|_calls]),
{*  writeCallPath('7 Call Path: '),  *}
  !.


{* The current call has been evaluated (not necessarily completed) and can be *}
{* removed from the stack of ACTIVE calls. By iteration it can join the active*}
{* calls again later.                                                         *}

popActiveCall :-
  pc_recorded(ACTIVE,'LIST',[_first|_rest]),
  pc_rerecord(ACTIVE,'LIST',_rest),
{*  writeCallPath('10 Call Path: '), *}
  !.

popActiveCall :-
  write('This call popActiveCall should never occur!'),nl,
  !,
  fail.

reportRest([]) :-
{*  write('No more active calls on stack '),nl, *}
  !.
reportRest([_cacheSlotId|_]) :-
{*  write('Computation continues with '),write(_cacheSlotId),nl, *}
  !.

writeCacheSlot( (_argkey,_predname) ) :-
  write_predname(_predname),write_lcall(_argkey),
  !.



currentActiveCall(_cacheSlotId) :-
  pc_recorded(ACTIVE,'LIST',[_cacheSlotId|_calls]),
  !.




{* iterate_prove_explicit is the 'inner' iteration for a call. *}
{* If the call of _lit is ground, we only have to prove it     *}
{* once in order to know that it's completely evaluated.       *}
{* Otherwise, we repeat to derive solutions until we do not    *}
{* find further solutions onder the current state of caches.   *}
{* If the callstate at the end of the iteration is still       *}
{* 'pending' then we know that there was not a 'dirty read'.   *}
{* Then, we can set the call state to 'completed'.             *}

{* else we iterate until we find no more facts in this iteration *}
iterate_prove_explicit(_lit,_clit,_cacheSlotId) :-
  repeat,               {* we iterate on backtracking until nothing more is added to the fact cache *}
    prove_and_store(_lit,_clit,_cacheSlotId),   {* a fail will trigger the next iteration *}
  getCallState(_cacheSlotId,_state),
  transCallState(_cacheSlotId,_state,'NoMoreFacts'),
  !.                            {* exit to monster_iterate *}



transCallState(_cacheSlotId,_oldstate,'NoMoreFacts') :-
  (
   _oldstate='pending';
   _oldstate='recursive';
   _oldstate='incomplete'  {* ticket #79: complete a cache slot also at exiting monster_iterate *}
  ),
  setCallState(_cacheSlotId,'completed'),
{*  writeCallPath('slot completed '),  *}
  checkSubSumptionObligations(_cacheSlotId),
  !.

transCallState(_cacheSlotId,_,_) :- !.


{* This is to derive one solution for a ground call        *}
{* If we cannot prove it, we only know that it cannot      *}
{* be prove if there was no dirt read, i.e. the call state *}
{* at the end of the iteration is still 'pending'.         *}
{* Otherwise, the callstate will be 'dirty'.               *}

prove_once_and_store(_lit,_clit,_cacheSlotId) :-
  prove_explicit(_lit),
  storeToCache(_clit,_cacheSlotId),
  setCallState(_cacheSlotId,'completed'),
  !.
prove_once_and_store(_lit,_clit,_cacheSlotId) :-
  getCallState(_cacheSlotId,_state),
  transCallState(_cacheSlotId,_state,'NoMoreFacts'),
  !.


{* prove_and_store will backtrack over explicit proofs of _lit *}
{* Finally, it will succeed if there are no more solutions     *}
{* in the current iteration, or fail in order to start a new   *}
{* iteration.                                                  *}

prove_and_store(_lit,_clit,_cacheSlotId) :-
  prove_explicit(_lit),            {* one execution of the matching deductive rule set *}
  addToCache(_clit,_cacheSlotId),
  fail.  {* until prove_explicit has no more solution *}


{* succeed only if we can exit iterate_prove_explicit *}
prove_and_store(_lit,_clit,_cacheSlotId) :-
   getCacheContent(_cacheSlotId,_state,[_token|_]),
   !,
{*   writeCallPath('exit inner '),  *}
   exitInnerLoop(_cacheSlotId,_state,_token).


{* ticket #213: also exit the inner loop iterate_prove_explicit if the state of the *}
{* iterated literal is pending after the current iteration. So, if no problem with  *}
{* dirty reads occurred, then we have completely computed the extension of the      *}
{* iterated literal. Otherwise, we will continue with the inner loop.               *}
{* If the state of the call is 'recursive', then we do not exit the inner loop.     *}
{* Recursive calls depend on their own cache slot. Hence, we need iterate their     *}
{* evaluation (using the current cache slot content) until no more facts are found. *}


exitInnerLoop(_,_,'sync') :-  !.    {* last iteration has not yielded a new fact for the iterated literal *}
exitInnerLoop(_,'pending',_) :-  !. {* iterated literal is now completely evaluated *}

{* else: do not exit the inner loop *}
exitInnerLoop(_cacheSlotId,_,_) :-
   addSyncPoint(_cacheSlotId),   {* add a sync point for the next inner loop iteration *}
   !,
   fail.



{* definePred enters _predname into the list of   *}
{* Mostly used for erasing the cache later.       *}
{* 12-Jul-2005: Only store _predname as known.    *}
{* The corresponding _argkeys can be retrieved    *}
{* directly from the cached facts.                *}

definePred(_lit,(_argkey,_predname)) :-
  pc_recorded('CachePredicate',_prednames),
  storePred(_lit,(_argkey,_predname),_prednames),
  !.

definePred(_lit,(_argkey,_predname)) :-
  pc_record('CachePredicate',[_predname]).


storePred(_lit,(_argkey,_predname),_prednames) :-
  memberchk(_predname,_prednames),
  !.
storePred(_lit,(_argkey,_predname),_prednames) :-
  pc_rerecord('CachePredicate',[_predname|_prednames]).



{* This checks whether there is a deductive rule or query deriving _lit: *}
{* 15-Mar-2002/MJf: isDeducable may not unify call arguments!            *}
{* This would lead to unwanted unifications of arguments of _lit because *}
{* the rule base can contain multiple rules with head matching _lit but  *}
{* whose head predicate is exposing different bindings of parameters to  *}
{* constants.                                                            *}
{* Example:  Call pred(_x,c1,_y)                                         *}
{*  Rule 1:   pred(_x,c1,c2) :- ....                                     *}
{*  Rule 2:   pred(c3,c1,_z) :- ....                                     *}
{* Here we must preserve the fact that both parameters _x,_y are indeed  *}
{* free variables. Otherwise we wouldn't call both rules in save_prove.  *}


{* work-around for ticket #325: the test of isDeducable fails for a strange *}
{* reason for certain ground predicates. We thus make the test for the non- *}
{* ground version of the predicate.                                         *}

isDeducable(Adot(_cc,_x,_y)) :-
  ground(_cc),ground(_x),ground(_y), 
  isDeducable_ng(Adot(_cc,_,_)),
  !.
isDeducable(In(_x,_c)) :-
  ground(_x),ground(_c), 
  isDeducable_ng(In(_,_c)),
  !.
isDeducable(_lit) :-
  isDeducable_ng(_lit).


isDeducable_ng(_lit) :-
  \+ notDeducable(_lit),  {* double negation to prevent variable unification *}
  !.
notDeducable(_lit) :-
  \+ IS_DEDUCABLE(_lit),   {* see also precompute_DEDUCABLE *}
  !.


{* checkIsDeducableByRule is a service function for FragmentToPropositions *}
{* Will deliver all literal patterns _lit that are derivable by a rule.    *}

checkIsDeducableByRule(_lit) :-
  isRuleHead(LTevalRule(_cc,_lit)),
  matchRuleHead(LTevalRule(_cc,_lit),_lit).

{* 22-Dec-2004/M.Jeusfeld: pre_compute facts IS_DEDUCABLE(_lit) to *}
{* speed up predicate isDeducable. I also tested the effect of     *}
{* pre-computung a fact IS_NONRECURSIVE but that had too little    *}
{* effect on the performance.                                      *}
{* We initialize the facts in startCBserver, then we refresh them  *}
{* after each update. We could limit the refresh to those update   *}
{* events that assert new rules or queries. But that is probably   *}
{* not worth the programming effort since precompute_DEDUCABLE is  *}
{* rather fast.                                                    *}


precompute_DEDUCABLE :-
  retractall(IS_DEDUCABLE(_)),
  cleanCachedSpeedyFacts,   
  isRuleHead(_head),
  checkToAddIsDeducable(_head),
  fail.
precompute_DEDUCABLE.

{* This procedure is also used in PROLOGruleProcessor.pro to keep the facts *}
{* IS_DEDUCABLE up-to-date during a transaction that adds no rules/queries  *}
checkToAddIsDeducable(_head) :-
  cleanCachedSpeedyFacts,  
  matchRuleHead(_head,_lit),
  tryStore(IS_DEDUCABLE(_lit)),
  !.

{* tryStore stores facts of type IS_DEDUCABLE(_lit). For each distinct predicate *}
{* signature P(x1,x2,..) where x1 etc. are variables or constants, only one fact *}
{* is stored. To check whether a predicate signature is already stored, we use   *}
{* getAbstractCall which exactlly computes the predicate signature.              *}

{* This check used to be much simpler but it caused the bug of ticket #119.      *}

{* case 1: the signature is already stored *}
tryStore(IS_DEDUCABLE(_lit)) :-
  getAbstractCall(_lit,_cacheSlotId,_clit),  
  IS_DEDUCABLE(_lit1), 
  getAbstractCall(_lit1,_cacheSlotId,_clit),  {* _lit and _lit1 would have same cache slot id *}
  !.
{* case 2: it was not stored *}
tryStore(IS_DEDUCABLE(_lit)) :-
{*  write('IS_DEDUCABLE:'),write_lcall(_lit),nl,  *}
  assert(IS_DEDUCABLE(_lit)).


isRuleHead(LTevalRule(_cc,_lit)) :-
  clause(LTevalRule(_cc,_lit),_).

isRuleHead(LTevalQuery(_cc,_lit)) :-
  clause(LTevalQuery(_cc,_lit),_).


matchRuleHead(LTevalRule(_cc,Adot(_cc,_x,_y)),Adot(_cc,_x,_y)) :- !.  

matchRuleHead(LTevalRule(_cc,Adot_label(_cc,_x,_y,_l)),Adot_label(_cc,_x,_y,_l)) :- !.

matchRuleHead(LTevalRule(_class,In(_x,_class)),In(_x,_class)) :- !.

matchRuleHead(LTevalQuery(_class,In(_x,_class)),In(_x,_class)) :- !.

matchRuleHead(LTevalQuery(_f,_lit),_lit) :-
  !.



{ Eigentlich muessten bei In auch Regeln von Subklassen ausgewertet werden,
 das verursacht aber manchmal unerwuenschte Endlosschleifen, deswegen ist es
 erstmal auskommentiert. Feb-2000/CQ}
{* Dies ist nun der Fall, allerdings wird es by prove_In realisiert. 12-Jan-2005/M.Jeusfeld *}

{* Ticket #145: additional case to be introduced for variable _c.*}
{* We only call LTevalRule since LTevalquery would also trigger  *}
{* calling almost all pre-defined query classes such as          *}
{* find_instances and so forth. Those query classes may however  *}
{* only be called with instantiated parameters.                  *}
prove_explicit(In(_x,_c)) :-
  var(_c),
  !,
  LTevalRule(_c,In(_x,_c)).

prove_explicit(In(_x,_c)) :-
   !,    {* no other clause applicable *}
   ground(_c),
   (LTevalQuery(_c,In(_x,_c));
    LTevalRule(_c,In(_x,_c))
   ).


prove_explicit(Adot(_cc,_x,_y)) :-
   LTevalRule(_cc,Adot(_cc,_x,_y)).


prove_explicit(Adot_label(_cc,_x,_y,_l)) :-
   LTevalRule(_cc,Adot_label(_cc,_x,_y,_l)).


prove_explicit(_lit) :-
   _lit =.. [_f|_], _f \== Adot, _f \== Adot_label,
   LTevalQuery(_f,_lit).


{* reverse predname and argkey to form the key for accessing callstate *}
getCallState((_argkey,_predname),_state) :-
  pc_recorded(_predname,_argkey,_state).    


setCallState((_argkey,_predname),completed) :-
  !,
{*  writeCacheSlot((_argkey,_predname)),write(' completed'),nl, *}
  do_setCallState((_argkey,_predname),completed).

setCallState((_argkey,_predname),_newstate) :-
  do_setCallState((_argkey,_predname),_newstate),
  !.

do_setCallState(_cacheSlotId,_newstate) :-
  _cacheSlotId = (_argkey,_predname),
  pc_recorded(_predname,_argkey,_oldstate),
  updateCallState(_cacheSlotId,_oldstate,_newstate),
{*  writeCallPath('2 Call Path: '),  *}
  !.
do_setCallState(_cacheSlotId,_newstate) :-
  _cacheSlotId = (_argkey,_predname),
  pc_record(_argkey,_predname,[sync]),    {* initialize cache with sync point for iterate_prove_explicit *}
  pc_record(_predname,_argkey,_newstate),             {* initialize call state *}
{*  writeCallPath('1 Call Path: '), *}
  !.

updateCallState(_,_oldstate,_newstate) :-
  _newstate = _oldstate,!.

updateCallState(_cacheSlotId,_oldstate,_newstate) :-
  _cacheSlotId = (_argkey,_predname),
  pc_rerecord(_predname,_argkey,_newstate).

initCallState(_cacheSlotId) :-
  _cacheSlotId = (_argkey,_predname),
  pc_record(_argkey,_predname,[sync]),    {* initialize cache with sync point for iterate_prove_explicit *}
  pc_record(_predname,_argkey,'pending'),             {* initialize call state *}
{*  writeCallPath('1 Call Path: '), *}
  !.



{* getFromCache delivers the entries of a cached predicated, one after the   *}
{* other. If the call reads from an incomplete predicate when that is still  *}
{* under evaluation (still an ACTIVE call), then we only have to return the  *}
{* new entries of the incomplete predicates (semi-naive fixpoint evaluation) *}


getFromCache(_lit,_cacheSlotId) :-
  getCacheContent(_cacheSlotId,_state,_lits),
  markCallPathOnDirtyRead(_lit,_state,_cacheSlotId,_deltamode),
  checkOnStoreEmptynessObligation(_cacheSlotId),   {* Ticket #79: take care of accesses to negated empty slots *}
  !,
  getmember(_deltamode,_lit,_lits).

getCacheContent(_cacheSlotId,_state,_lits) :-
  _cacheSlotId = (_argkey,_predname),
  getCallState(_cacheSlotId,_state),
  pc_recorded(_argkey,_predname,_lits).


  


{* 29-Aug-2002/M. Jeusfeld *}
{* Remark: It would be better (more correct) to apply the deltemember only in   *}
{* cases where the call of _lit reads from an incompleted cache to which it had *}
{* a 'dirty read' earlier. Hence, the current way of recordiong dirty reads     *}
{* forgets from where to where a dirty read has happend.                        *}


getmember('delta',_lit,_lits) :-
  !,
  deltamember(_lit,_lits).    {* only entries that were added in last iteration *}

getmember(_,_lit,_lits) :-
  pc_member(_lit,_lits).  {* else all facts! *}

deltamember(_lit,[sync|_rest]) :- !, deltamember2(_lit,_rest).
deltamember(_lit,[_lit|_]).
deltamember(_lit,[_|_rest]) :- deltamember(_lit,_rest).

deltamember2(_lit,[sync|_rest]) :- !,fail.
deltamember2(_lit,[_lit|_]).
deltamember2(_lit,[_|_rest]) :- deltamember2(_lit,_rest).



{* This maintains the callstates 'dirty' and 'incomplete'              *}
{* A dirty read is defined as follows:                                 *}
{* A current call X accesses the cache of a call Y (identified by      *}
{* _argkey,_predname) while call Y is still not completed.             *}
{* Hence, the solutions to call X will be incomplete.                  *}

markCallPathOnDirtyRead(_lit,_state,_cacheSlotId,_deltamode) :-
  (_state = 'pending';_state='incomplete';_state='recursive'),
                       {* this cache was accessed when still in pending/incomplete state *}
                       {* we won't change the state of calls when they are    *}
                       {* already dirty or incomplete                         *}
  checkDeltaMode(_cacheSlotId,_deltamode),
  updateCallPath(_cacheSlotId),
  !.

markCallPathOnDirtyRead(_lit,_state,_cacheSlotId,'all').


{* This controls whether getmember will take all cache content or only   *}
{* the entries of the last inner iteration.                              *}
{* Remark 29-Aug-2002/M.Jeusfeld: It should better be the entries in the *}
{* monster iteration???                                                  *}

checkDeltaMode(_cacheSlotId,'all') :-
  (currentActiveCall(_cacheSlotId);    {* = access to cache comes directly from cached call *}
   not(currentActiveCall(_))                   {* = the computation of all calls is completed       *}
  ),
  !.

checkDeltaMode(_cacheSlotId,'delta').



{* updateCallPath marks the current call as dirty (if it doesn't just access *}
{* its own cache which is matter of the inner iteration) and pushes the      *}
{* incomplete call upwards to _cacheSlotId if that is older than             *}
{* the current 'incomplete' call in the stack of ACTIVE calls.               *}
{* So, the states of ACTIVE calls have the following patterns:               *}
{*   [dirty,pending,dirty,....,incomplete,pending,pending]                   *}
{* There is at most one incomplete call (the highest in the call path). Only *}
{* on this call we do the monster iteration. The dirty calls get then        *}
{* reevaluated when a new iteration on the incomplete call is due.           *}

updateCallPath(_cacheSlotId) :-
{*  checkOnStoreEmptynessObligation(_cacheSlotId), *}
  setCurrentDirty(_cacheSlotId),  {* if this fails, we don't update anything *}
  pc_recorded(ACTIVE,'LIST',_calls),
  setDependencies(_calls,_cacheSlotId),
  moveIncompleteUp(_cacheSlotId,_calls),
  setPendingDirty(_cacheSlotId,_calls),  {* all pending calls younger than _cacheSlotId are now dirty *}
{*  writeCallPath('8 Call Path: '), *}
  !.

updateCallPath(_cacheSlotId).


{* The current is only set dirty if it did not refer to its own cache. *}
{* The _cacheSlotId comes from a getFromCache call.                    *}

setCurrentDirty(_cacheSlotId) :-
  currentActiveCall(_currentCall),
  _cacheSlotId \== _currentCall,
  setCallState(_currentCall,'dirty'),
  !.

{* Ticket #79 *}
{* take care of dirty reads to own cache when call is negated!!!   *}
checkOnStoreEmptynessObligation(_cacheSlotId) :-
  isNegatedNonComplete(_cacheSlotId),
  storeEmptynessObligation(_cacheSlotId),   {* then is must remain empty *}
{*  writeCallPath('9 Call Path: '), *}
  !.
checkOnStoreEmptynessObligation(_).


isNegatedNonComplete(_cacheSlotId) :-
  isNegatedCall(_cacheSlotId),              {* call is negated   *}
  getCacheContent(_cacheSlotId,_state,_facts), 
  _state \== 'completed',                   {* cache not completed *}
  (_facts = []; _facts = [sync]),            {* and cache is empty *}
  !.

storeEmptynessObligation(_cacheSlotId) :-
  pc_recorded(EMPTYNESSOBLIGATIONS,_currenttests),
  try_storeEmptynessObligation(_cacheSlotId,_currenttests),
  !.

storeEmptynessObligation(_cacheSlotId) :-
  pc_record(EMPTYNESSOBLIGATIONS,[_cacheSlotId]).

try_storeEmptynessObligation(_cacheSlotId,_currenttests) :-
  memberchk(_cacheSlotId,_currenttests),  {* already known *}
  !.

try_storeEmptynessObligation(_cacheSlotId,_currenttests) :-
  pc_rerecord(EMPTYNESSOBLIGATIONS,[_cacheSlotId|_currenttests]).

removeEmptynessObligation(_cacheSlotId,_currenttests) :-
  setDifference(_currenttests,[_cacheSlotId],_newtests),
  updateEmptynessObligations(_newtests),
  !.
removeEmptynessObligation(_,_). {* never fail *}

updateEmptynessObligations(_tests) :-
  pc_rerecord(EMPTYNESSOBLIGATIONS,_tests),
  !.



 

{* Tickets #79,#179 *}
{* When an incomplete call is finally set to completed, then its   *}
{* dirty readers shall be set to pending.                          *}
{* This is done recursively.                                       *}

setDirtyReadersToPending(_cacheSlotId) :-
  isDirtyReader(_slot,_cacheSlotId),
{*  setCallState(_slot,'completed'),  see ticket #179*}
  setCallState(_slot,'pending'), 
  setDirtyReadersToPending(_slot),
  fail.

setDirtyReadersToPending(_).
   



{* setDependencies establishes a 'READSDIRTYFROM' dependency between all calls starting from          *}
{* the current active call up to (and excluding) the 'supplier' call whose cache got a 'dirty read'   *}
{* These calls are then re-entrant and may read new facts added to the supplier call.                 *}
{* See also welcome_fresh_call.                                                                       *}

setDependencies([],_) :- !.

setDependencies([_supplier|_rest],_supplier) :- !.  {* here ends the setting of dirty readers *}

setDependencies([_consumer|_rest],_supplier) :-
  setDependency(_consumer,_supplier),
  setDependencies(_rest,_supplier).




{* dieses Flag sorgt dafuer, dass in TellAndAsk.pro als completion 'error'  *}
{* erzeugt wird, wenn ein Stratifikationsfehler gefunden wurde.             *}

raiseStratificationError :-  stratificationErrorFound,!.  {* already raised *}
raiseStratificationError :-  assert(stratificationErrorFound).

stratificationErrorRaised :-
  retract(stratificationErrorFound),
  !.

resetStratificationError :-
  retract(stratificationErrorFound),
  !.
resetStratificationError.



setDependency(_consumer,_supplier) :-
  _consumer = (_ca,_cp),
  _supplier = (_sa,_sp),
  pc_atomconcat(_ca,_cp,_consumerId),  {* combine the two components identifying a call *}
  pc_atomconcat(_sa,_sp,_supplierId),
  storeDependency(_consumerId,_supplierId),
  !.


storeDependency(_consumerId,_supplierId) :-
  pc_recorded(_consumerId,READSDIRTYFROM,_suppliers),
  tryStoreDep(_consumerId,_supplierId,_suppliers),
  !.

storeDependency(_consumerId,_supplierId) :-
  pc_record(_consumerId,READSDIRTYFROM,[_supplierId]),
{*  write_callid(_consumerId),write(' reads dirty from '),write_callid(_supplierId),nl, *}
  !.

tryStoreDep(_consumerId,_supplierId,_suppliers) :-
  memberchk(_supplierId,_suppliers),
  !.

tryStoreDep(_consumerId,_supplierId,_suppliers) :-
  pc_rerecord(_consumerId,READSDIRTYFROM,[_supplierId|_suppliers]),
{*  write_callid(_consumerId),write(' reads dirty from '),write_callid(_supplierId),nl,  *}
  !.

{* example callid: '[Xx1]+id_1621' *} 
write_callid(_callid) :-
  atom(_callid),
  pc_atom_to_term(_callid,_term),
  _term = _arglist+_functor,
  _call =.. [_functor|_arglist],
  write_lcall(_call),
  !.

write_callid(_callid) :- write(_callid).
  


{* This checks for a call _consumer whether is was previously a dirty reader of the cache _supplier *}
{* both arguments have to be instantiated.                                                          *}

readsDirtyFrom(_consumer,_supplier) :-
  _consumer = (_ca,_cp),
  _supplier = (_sa,_sp),
  pc_atomconcat(_ca,_cp,_consumerId),
  pc_atomconcat(_sa,_sp,_supplierId),
  pc_recorded(_consumerId,'READSDIRTYFROM',_suppliers),
  memberchk(_supplierId,_suppliers),
  !.

readsDirtyFrom_Atom(_consumerId,_supplier) :-
  _supplier = (_sa,_sp),
  pc_atomconcat(_sa,_sp,_supplierId),
  pc_recorded(_consumerId,'READSDIRTYFROM',_suppliers),
  memberchk(_supplierId,_suppliers),
  !.




{* Ticket #79 *}
{* isDirtyReader(_consumer,_supplier) is true if _consumer is a dirty reader of *}
{* _supplier. Argument _consumer can be a variable.                             *}

{* if we ever need that _supplier may be a variable, then un-comment this clause *}
{*
isDirtyReader(_consumer,_supplier) :-   
  var(supplier),!,
  pc_current_key(_consumerAtom,'READSDIRTYFROM'),
  slotAtomToSlotId(_consumerAtom,_consumer),
  getCallState(_consumer,'dirty'),
  pc_recorded(_consumerAtom,'READSDIRTYFROM',_suppliers),
  pc_member(_supplierAtom,_suppliers),
  slotAtomToSlotId(_supplierAtom,_supplier).
*}

isDirtyReader(_consumer,_supplier) :-
  _supplier  = (_sa,_sp),
  pc_atomconcat(_sa,_sp,_supplierAtom),
  pc_current_key(_consumerAtom,'READSDIRTYFROM'),
  slotAtomToSlotId(_consumerAtom,_consumer),
  getCallState(_consumer,'dirty'),
  pc_recorded(_consumerAtom,'READSDIRTYFROM',_suppliers),
  pc_member(_supplierAtom,_suppliers).



slotAtomToSlotId(_slotAtom,(_argkey,_predname)) :-
  pc_save_atom_to_term(_slotAtom,_slotexpr),
  _slotexpr =.. [_sign,_args,_pred],
  pc_atomconcat(_sign,_pred,_predname),
  atom2term(_argkey,_args),
  !.



{* Updates the 'incomplete' call in the the current stack of active calls *}
{* The incomplete call is iterated over by monster_iterate. It is         *}
{* defined to be the oldest call in the active calls that has received    *}
{* a dirty read.                                                          *}

moveIncompleteUp(_cacheSlotId,[_firstCall|_rest]) :-
  getCallState(_firstCall,'incomplete'),   {* the current incomplete call  *}
  memberchk(_cacheSlotId,_rest),           {* is younger than _cacheSlotId *}
  setCallState(_firstCall,'dirty'),        {* it will now be dirty under iteration of the new incomplete call *}
  setCallState(_cacheSlotId,'incomplete'),  {* this is the new iterating call *}
  !.

moveIncompleteUp(_cacheSlotId,[_cacheSlotId|_rest]) :-  {* first call in list is not an older incomplete call *}
  isIncompleteInRest(_rest),
  setCallState(_cacheSlotId,'dirty'),  {* shall be regarded as dirty under iteration of existing incomplete call *}
  !.

moveIncompleteUp(_cacheSlotId,[_first|_rest]) :-
  moveIncompleteUp(_cacheSlotId,_rest).

moveIncompleteUp(_cacheSlotId,[]) :-
  setCallState(_cacheSlotId,'incomplete').  {* this is the first pred to be found as incomplete *}

isIncompleteInRest([_someCallId|_]) :-
  getCallState(_someCallId,'incomplete'),
  !.

isIncompleteInRest([_|_rest]) :-
  isIncompleteInRest(_rest).


{* pending calls younger than an new incomplete call that just received a dirty read *}
{* must also become dirty since they depend on new solutions for the incomplete      *}
{* call.                                                                             *}

setPendingDirty(_cacheSlotId,[]) :- !.

setPendingDirty(_cacheSlotId,[_cacheSlotId|_]) :- !.

setPendingDirty(_cacheSlotId,[_first|_rest]) :-
  getCallState(_first,'pending'),
  setCallState(_first,'dirty'),
  !,
  setPendingDirty(_cacheSlotId,_rest).

setPendingDirty(_cacheSlotId,[_|_rest]) :-
  setPendingDirty(_cacheSlotId,_rest).











{* By sync points we detect whether something was added a a given *}
{* cache denoted by (_argkey,_predname).                          *}

addSyncPoint((_argkey,_predname)) :-
  pc_recorded(_argkey,_predname,[sync|_lits]),  {* there is already a sync as first cache entry *}
  !.

{* if we have a sync as 2nd entry, we just move it to the head instead of adding a new *}
{* sync point. This keeps the caches small and makes lookup faster                     *}
addSyncPoint((_argkey,_predname)) :-
  pc_recorded(_argkey,_predname,[_lit,sync|_restlits]),
  _lit \== sync,
  pc_rerecord(_argkey,_predname,[sync,_lit|_restlits]),  {* move sync point to head *}
  !.

addSyncPoint((_argkey,_predname)) :-
  pc_recorded(_argkey,_predname,_lits),
  pc_rerecord(_argkey,_predname,[sync|_lits]),  {* add a new sync point *}
  incrementCacheSize,                                 {* a sync also counts as cache entry *}
  !.

addSyncPoint((_argkey,_predname)) :-
  write('Literals.pro:This addSyncPoint should never occur: '), writeCacheSlot((_argkey,_predname)),nl,
  fail.


{* if there is only one possible solution, we just store it *}
storeToCache(_lit,(_argkey,_predname)) :-
  pc_rerecord(_argkey,_predname,[_lit]),
  checkEmptynessObligations((_argkey,_predname)),
  incrementCacheSize,
  establishSubsumptionObligation( (_argkey,_predname) ),
  markWritten(_argkey,_predname),
  !.


addToCache(_lit,(_argkey,_predname)) :-
  pc_recorded(_argkey,_predname,_lits),
  storeLit(_lit,_argkey,_predname,_lits),
  !.

storeLit(_lit,_argkey,_predname,_lits) :-
  memberchk(_lit,_lits),
{*  write_lcall(_lit),write(' was already in cache '),nl, *}
  !,
  fail.
 {* if _lit is already in the cache we can fail the call of addToCache to save evaluation time *}
 {* As it was already computed, this failure will not change the extension of the original     *}

storeLit(_lit,_argkey,_predname,_lits) :-
  pc_rerecord(_argkey,_predname,[_lit|_lits]),
  checkEmptynessObligations((_argkey,_predname)),      {* ticket #79 *}
{*  writeCallPath('3 Call Path'), *}
  incrementCacheSize,
{*  write('New fact '),write_lcall(_lit), write(' for '),write_predname(_predname),write_lcall(_argkey),nl, *}
  establishSubsumptionObligation( (_argkey,_predname) ),  {* see CBNEWS[210] *}
  markWritten(_argkey,_predname).


markWritten(_argkey,_predname) :-
  pc_recorded(CACHEWRITTEN,_somecache),  {* sufficient to know that some cache got a new fact *}
  !.

{* otherwise we mark tha cache of (argkey,predname) as written *}
{* This will be checked in monster_iterate                     *}
markWritten(_argkey,_predname) :-
  pc_record(CACHEWRITTEN,(_argkey,_predname)),
  !.

{* remove the flag as soon as we have checked it in welcome_fresh_call *}
{* ticket #288                                                         *}
isWritten(_cacheSlotId) :-
  pc_recorded(CACHEWRITTEN,_cacheSlotId),
  pc_erase(CACHEWRITTEN).  
  


{* Subsumption test for non-stratified predicate calls              *}
{* It can occur that a predicate -P(a,b,c) is called in negated form*}
{* with all arguments being constants and this call occurs during   *}
{* the evaluation of a subsuming positive call +P(a,b,X) where one  *}
{* or more arguments are variables. If the evaluation of -P(a,b,c)  *}
{* turns out that P(a,b,c) is actually true, then we expect that the*}
{* call +P(a,b,X) will also contain the fact P(a,b,c), i.e. a       *}
{* solution X=c. When that is not the case, we have a stratification*}
{* violation (type 3).                                              *}
{* An example is the query ShavedByBarber in Barber.sml of the      *}
{* CB-Forum. The call A(TheBarber,shaves,X) is reduced to the       *}
{* negated call not A(TheBarber,shaves,TheBarber). The negated call *}
{* would fail (i.e. A(TheBarber,shaves,TheBarber) succeeds) but the *}
{* earlier call  A(TheBarber,shaves,X) does not return X-TheBarber. *}
{* This is paradoxical and constitutes a violation of dynamic       *}
{* stratification.                                                  *}
{* We detect this situation as follows:                             *}
{*  Step 1: When a negated call fails (i.e. the predicate succeeds) *}
{*          we check whether there is a matching positive call      *}
{*          in the call path (e.g. -P(a,b,c) matches the call       *}
{*          +P(a,b,X).                                              *}
{*  Step 2: If we have a match, we create a SUBSUMEDBY link between *}
{*          the argkey of the negated call and the matching         *}
{*          call. That means that we expect that a fact specified by*}
{*          argkey will show up later in the cache of the positive  *}
{*          call.                                                   *}
{*  Step 3: When the positive call is completed, i.e. its state is  *}
{*          set to 'completed', we call the test                    *}
{*            checkSubSumptionObligations(_completedCashSlot)       *}
{*          The test will find out whether the expected facts are   *}
{*          actually in the cache of _completedCashSlot. If not, we *}
{*          can raise an error message STRATIFICATION_VIOLATION2.   *}
{*                                                                  *}
{* Note that facts in the caches have the form t(x,y,..) where x,   *}
{* y, .. are the free arguments of the predicate call. For example, *}
{* The predicate call P(a,b,X) would induce fact format t(X).       *}




{* Whenever a fact is stored in the cache of a negated call, we need to *}
{* watch for subsumption obligations:                                   *}

establishSubsumptionObligation(_cacheSlotId) :-
  isNegatedCall(_cacheSlotId),   {* only this case can establish stratification violations *}
  findSubsumingCacheSlots(_cacheSlotId),
  !.
establishSubsumptionObligation(_).  {* never fail *}

findSubsumingCacheSlots(_cacheSlotId) :-
  pc_recorded(ACTIVE,'LIST',_allSlots),   {* only search in those caches which are in the current call path *}
  scanSubsumingSlots(_cacheSlotId,_allSlots),
  !.

isNegatedCall(_cacheSlotId) :-
  _cacheSlotId = (_caA,_cpA),
  pc_atomprefix('-',1,_cpA),
  !.


scanSubsumingSlots(_cacheSlotId,[]) :- !.

scanSubsumingSlots(_cacheSlotId,[_subsumingSlot|_restCandidateSlots]) :-
  isSubsumedBy(_cacheSlotId,_subsumingSlot),
  createSubsumptionObligation(_cacheSlotId,_subsumingSlot),
  scanSubsumingSlots(_cacheSlotId,_restCandidateSlots).

scanSubsumingSlots(_cacheSlotId,[_|_restCandidateSlots]) :-
  scanSubsumingSlots(_cacheSlotId,_restCandidateSlots).

isSubsumedBy(_cacheSlotId,_subsumingSlot) :-
  _cacheSlotId = (_caA,_cpA),
  _subsumingSlot = (_caB,_cpB),
  matchingPreds(_cpA,_cpB),
  matchingArgs(_caA,_caB),
  !.

matchingPreds(_predA,_predB) :-
  pc_atomprefix('-',1,_predA), {* the subsumed predicate is negated *}
  pc_atomprefix('+',1,_predB), {* the subsuming predicate is positive *}
{*
  pc_atomconcat('-',_predrest,_predA),
  pc_atomconcat('+',_predrest,_predB),
*}
  !.

{* matchingArgs is much like Prolog match but note that the arguments *}
{* are here hidden in an argkey generated by getAbstractCall.         *}

matchingArgs(_caA,_caB) :-
  pc_atom_to_term(_caA,_argsA),
  pc_atom_to_term(_caB,_argsB),
  checkArgMatch(_argsA,_argsB),
  !.

checkArgMatch([],[]) :- !.

checkArgMatch([_xA|_restA],[_xB|_restB]) :-
  matchingArg(_xA,_xB),
  checkArgMatch(_restA,_restB).

matchingArg(_x,_x) :- !.
matchingArg(_x,_y) :-
  pc_atomprefix('Xx',2,_y).    {* _y is a free variable; use Xx so that we can reconstruct the Prolog call *}


createSubsumptionObligation(_cacheSlotId,_subsumingSlot) :-
{*  writeCacheSlot(_cacheSlotId),write(' is subsumed by '),writeCacheSlot(_subsumingSlot),nl, *}
  _cacheSlotId = (_ca,_cp),
  addSubsuming(_ca,_subsumingSlot).


{* The storage of the subsumtion obligation is with the usual pc_record/pc_recorded methods *}

addSubsuming(_argkey,_subsumingSlot) :-
  pc_recorded(_argkey,SUBSUMEDBY,_currentSubsumers),
  storeSubsuming(_argkey,_subsumingSlot,_currentSubsumers),
  !.

addSubsuming(_argkey,_subsumingSlot) :-
  pc_record(_argkey,SUBSUMEDBY,[_subsumingSlot]),
  !.

storeSubsuming(_argkey,_subsumingSlot,_currentSubsumers) :-
  memberchk(_subsumingSlot,_currentSubsumers),
  !.

storeSubsuming(_argkey,_subsumingSlot,_currentSubsumers) :-
  pc_rerecord(_argkey,SUBSUMEDBY,[_subsumingSlot|_currentSubsumers]),
  !.


{* This is the actual test of the subsumption obligation. It is called *}
{* in next to the predicate setCallState(...,'completed'), i.e. when   *}
{* our magic cache engine BELIEVES that cache would be completely      *}
{* evaluated ...                                                       *}
{* Since we need to test all subsumption obligations, we need to use   *}
{* Prolog negation.                                                    *}

checkSubSumptionObligations(_completedCashSlot) :-
  \+ missingFactInSubsumed(_completedCashSlot),
  !.


missingFactInSubsumed(_cacheSlotId) :-
  pc_current_key(_argkey,'SUBSUMEDBY'),
  pc_recorded(_argkey,SUBSUMEDBY,_cacheslots),
  memberchk(_cacheSlotId,_cacheslots),
  missingInCache(_argkey,_cacheSlotId).

missingInCache(_argkey,_cacheSlotId) :-
  _cacheSlotId = (_ca,_cp),
  formCacheFact(_argkey,_ca,_tfact),
  pc_recorded(_ca,_cp,_facts),
  \+ getmember('all',_tfact,_facts),
  readablePredname(_cp,_sign,_predname),
  readableArgkey(_argkey,_argkeylist1),
  readableArgkey(_ca,_argkeylist2),
  raiseStratificationError,  {* beeinflusst TellAndAsk.pro *}
{*  writeCallPath('5 Call Path: '), *}
  report_error(STRATIFICATION_VIOLATION2,Literals,[_sign,_predname,_argkeylist1,_argkeylist2]),
  !.


{* This forms the expected fact out of two argkeys. For example, if we *}
{* have argkey1=[a,b,c] and argkey2=[a,b,x1] then t(c) is the expected *}
{* cache fact.                                                         *}
{* Note that all variables start with 'Xx' cf. getAbstractCall          *}

formCacheFact(_argkey1,_argkey2,_tfact) :-
  pc_atom_to_term(_argkey1,_args1),
  pc_atom_to_term(_argkey2,_args2),
  extractBinds(_args1,_args2,_args),
  _tfact =.. [t|_args],
  !.

extractBinds([],[],[]) :- !.

extractBinds([_x|_rest1],[_x|_rest2],_args) :-
  extractBinds(_rest1,_rest2,_args).

extractBinds([_x|_rest1],[_y|_rest2],[_x|_rest]) :-
  pc_atomprefix('Xx',2,_y),    {* _y is a free variable *}
  extractBinds(_rest1,_rest2,_rest).


{* Ticket #79: test whether a a cache slot is non-emty even if we require it to *}
{* be empty. When called, we know that the cache of _cacheSlotId is non-empty.  *} 

checkEmptynessObligations(_cacheSlotId) :-
  pc_recorded(EMPTYNESSOBLIGATIONS,_currenttests),
  memberchk(_cacheSlotId,_currenttests),  {* YES, this one must be emty! *}
  raiseStratificationError,  {* beeinflusst TellAndAsk.pro *}
  _cacheSlotId=(_ca,_cp),
  readablePredname(_cp,_sign,_predname),
  readableArgkey(_ca,_argkeylist),
  report_error(STRATIFICATION_VIOLATION1,Literals,[_sign,_predname,_argkeylist]),
  removeEmptynessObligation(_cacheSlotId,_currenttests),
  !.
checkEmptynessObligations(_).




getLiteralCallSign(_lit,'-') :-
  forgetTrap(_lit),   {* secretly consumes that negated call trap of not_prove_literal !!! *}
  !.
getLiteralCallSign(_lit,'+').


getAbstractCall(_lit,(_argkey,_predname),_clit) :-
  getLiteralCallSign(_lit,_prefix),
{*  _lit =.. [_origpred|_orig_args], *}
  lit2PredArgs(_lit,_origpred,_orig_args), 
  pc_atomconcat(_prefix,_origpred,_predname), 
  makeArgsAbstract(_orig_args,_abstract_args),
  makeArgkey(_abstract_args,_argkey),
  getFreeVars(_orig_args,_freevars),
  _clit =.. ['t'|_freevars],
{*  write('Generated the cache predicate '),write(_clit),nl, *}
{*  write('Call '),write_lcall(_lit),write(' has argkey '),write(_argkey),nl, *}
  !.

{* This case is apparently not leading to faster access times 
lit2PredArgs(In(_x,_c),_c,[_x]) :-
  ground(_c),
  name2id(QueryClass,_qcid),
  \+ prove_In_e(_c,_qcid),
  !.
*}

lit2PredArgs(Adot(_cc,_x,_y),_cc,[_x,_y]) :-
  ground(_cc),
  !.

lit2PredArgs(_lit,_pred,_args) :-
  _lit =.. [_pred|_args].



formNegation(_cacheSlotId,_negCacheSlotId) :-
  _cacheSlotId=(_argkey,_predname),
  (_sign='+';_sign='-'),
  pc_atomconcat(_sign,_pred,_predname),
  negSign(_sign,_negsign),
  pc_atomconcat(_negsign,_pred,_negpredname),
  _negCacheSlotId=(_argkey,_negpredname),
  !.

negSign('+','-').
negSign('-','+').


makeArgkey(_args,_argkey) :- pc_atom_to_term(_argkey,_args).


getFreeVars([],[]).

getFreeVars([_x|_argrest],[_x|_vrest]) :-
  var(_x),!,
  getFreeVars(_argrest,_vrest).

getFreeVars([_x|_argrest],_vrest) :-
  getFreeVars(_argrest,_vrest).



{* 19-Mar-2002/MJf: We have to distinguish predicate calls P(_x,_x) from *}
{* predicate calls P(_x,_y). The extension of the first call pattern is  *}
{* not the same is for the second call pattern. Hence, use symbolic      *}
{* variable tags for occurences of variables in a call.                  *}
{* Previously, all variables got the tag '/f/'. Now they get tags        *}
{* 'Xx1' etc. When two variables in a call are identical, they will      *}
{* be assigned the same variable tag.                                    *}
{* The predicate call P(_x,_x) would get the abstract arguments [Xx1,Xx1]*}
{* and P(_x,_y) would get [Xx1,Xx2]. Note that the small caps 'x'        *}
{* is a Prolog atom.                                                     *}
{* We implicitely assume that Xx1 etc are not used as constants in       *}
{* ConceptBase formulas or as ConceptBase object names. Otherwise,       *}
{* the literal evaluation will produce wring results.                    *}


makeArgsAbstract(_orig_args,_abstract_args) :-
  do_makeArgsAbstract(_orig_args,[],1,_abstract_args).

do_makeArgsAbstract([],_vartable,_counter,[]) :- !.

do_makeArgsAbstract([_x|_restargs],_vartable,_counter,[_xtag|_restabstractargs]) :-
  var(_x),!,
  getVarTag(_x,_vartable,_newvartable,_counter,_newcounter,_xtag),
  do_makeArgsAbstract(_restargs,_newvartable,_newcounter,_restabstractargs).

do_makeArgsAbstract([_x|_restargs],_vartable,_counter,[_x|_restabstractargs]) :-
  atom(_x),!,
  do_makeArgsAbstract(_restargs,_vartable,_counter,_restabstractargs).

do_makeArgsAbstract([_x|_restargs],_vartable,_counter,[_x|_restabstractargs]) :-
   write('Literals.pro: ERROR in makeArgsAbstract: '),write(_x),
   write(' is not a variable or an atom.'),nl,!,fail.

{* case one: the variable was already occuring earlier *}
getVarTag(_x,_vartable,_vartable,_counter,_counter,_xtag) :-
  getFromVartable(_x,_vartable,_xtag),
  !.

{* case two: it's the first occurence of variable _x in the call *}
getVarTag(_x,_vartable,[(_x,_xtag)|_vartable],_counter,_newcounter,_xtag) :-
  pc_inttoatom(_counter,_catom),
  pc_atomconcat('Xx',_catom,_xtag),
  _newcounter is _counter + 1,
  !.

getFromVartable(_x,[(_y,_ytag)|_],_ytag) :-
  _x == _y,
  !.

getFromVartable(_x,[_|_rest],_xtag) :-
  getFromVartable(_x,_rest,_xtag).




