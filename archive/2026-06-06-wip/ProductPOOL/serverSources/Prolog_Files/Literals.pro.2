    _x == _y.
*}

prove_literal(EQ(_expr1,_expr2)) :-
    evalFunctionArg(_expr1,_tid1),
    evalFunctionArg(_expr2,_tid2),
    id2term(_tid1,_t1),
    id2term(_tid2,_t2),
    !,
    _t1 = _t2.

prove_literal(NE(_expr1,_expr2)) :-
    evalFunctionArg(_expr1,_tid1),
    evalFunctionArg(_expr2,_tid2),
    id2term(_tid1,_t1),
    id2term(_tid2,_t2),
    !,
    _t1 \= _t2.

prove_literal(TRUE) :- !.
prove_literal(FALSE) :- !,fail.



