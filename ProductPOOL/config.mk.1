   endif
   JAVADIR:=/usr
   CC:=/usr/bin/gcc-4.4
   CXX:=/usr/bin/g++-4.4
#   CC:=/usr/bin/clang
#   CXX:=/usr/bin/clang++
   ifdef CB_CC
     CC:=$(CB_CC)
   endif 
   ifdef CB_CXX
     CXX:=$(CB_CXX)
   endif 

   LATEX2HTML=/home/jeusfeld/CBPOOL/AdminPOOL/utils/latex2html/latex2html
   ifndef SWI_HOME
     SWI_HOME:=/home/jeusfeld/swiprolog
     SWI_INCLUDE:=$(SWI_HOME)/lib/pl-5.7.10/include
   endif
endif
