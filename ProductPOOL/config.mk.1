#------------------------------------------------------
# Prolog-Compiler und Interpreter
#------------------------------------------------------
# allgemein
CB_PPP=$(JAVA) -classpath $(CB_POOL)/java/classes i5.cb.PrologPreProcessor

ifeq "$(PROLOG_VARIANT)" "BIM"
  PROLOG_PP_OBJECTS=$(patsubst %.pro,%.bim.pro,$(PROLOG_SOURCES))

ifeq "$(CB_VARIANT)" "i86pc"
  PROLOG_COMP=$(BIM_PROLOG_DIR)/bin/BIMpcomp
  PROLOG_OFLAG=-o#
  PROLOG_COMP_FLAGS=-A6
  PROLOG_TEST=$(PROLOG_COMP) -oPROLOG_TEST.wic $(PROLOG_COMP_FLAGS) $< && \
	$(RM) PROLOG_TEST.wic
  PROLOG_OBJECTS=$(addprefix $(OBJDIR)/,$(patsubst %.pro,%.wic,$(PROLOG_SOURCES)))
  PROLOG_INTERPRETER=$(BIM_PROLOG_DIR)/bin/BIMprolog
  PROLOG_INT_FLAGS=
else # sun4, linux, windows
  PROLOG_COMP=$(PL_HOME)/bin/PLcomp
  PROLOG_COMP_FLAGS=-A6 -c-
  PROLOG_OFLAG=-o #
  PROLOG_TEST=$(PROLOG_COMP) -o PROLOG_TEST.wic $(PROLOG_COMP_FLAGS) $< && \
	$(RM) PROLOG_TEST.wic
  PROLOG_OBJECTS=$(addprefix $(OBJDIR)/,$(patsubst %.pro,%.wic,$(PROLOG_SOURCES)))
  PROLOG_VARIANT_SOURCES=$(patsubst %.pro,%.bim.pro,$(PROLOG_SOURCES))
  PROLOG_INTERPRETER=$(PL_HOME)/bin/PLeng
  PROLOG_INT_FLAGS=
endif
endif

ifeq "$(PROLOG_VARIANT)" "SWI"
  PROLOG_PP_OBJECTS=$(patsubst %.pro,%.swi.pl,$(PROLOG_SOURCES))
  PROLOG_COMP_FLAGS=-c
  PROLOG_OFLAG=-o #
  PROLOG_OBJECTS=#$(addprefix $(OBJDIR)/,$(patsubst %.pro,%.swo,$(PROLOG_SOURCES)))
  PROLOG_VARIANT_SOURCES=$(patsubst %.pro,%.swi.pl,$(PROLOG_SOURCES))
  PROLOG_INT_FLAGS=
  ifeq "$(CB_VARIANT)" "windows"
    ifndef SWI_HOME
      SWI_HOME=p:/SWI/windows
      SWI_INCLUDE=$(SWI_HOME)/include
    endif
    SWI_PLLD=$(SWI_HOME)/bin/plld.exe
    PROLOG_COMP=$(SWI_HOME)/bin/plcon
    PROLOG_INTERPRETER=$(SWI_HOME)/bin/plcon
  else
    ifeq "$(CB_VARIANT)" "mac"
       ifndef SWI_HOME
          SWI_HOME=/opt/local
          SWI_INCLUDE=$(SWI_HOME)/lib/swipl-5.6.48/include/
       endif
       SWI_PLLD=$(SWI_HOME)/bin/plld
       PROLOG_COMP=$(SWI_HOME)/bin/swipl
       PROLOG_INTERPRETER=$(SWI_HOME)/bin/swipl
       SWI_HOME_DIR=$(SWI_HOME)/lib/swipl-5.6.48
       export SWI_HOME_DIR
    else
      ifndef SWI_HOME
        SWI_HOME=/home/prolog/SWI/$(CB_VARIANT)-5.6.23
        SWI_INCLUDE=$(SWI_HOME)/lib/pl-5.6.23/include
      endif
      SWI_PLLD=$(SWI_HOME)/bin/plld
      PROLOG_COMP=$(SWI_HOME)/bin/pl
      PROLOG_INTERPRETER=$(SWI_HOME)/bin/pl
    endif
   endif
#  SWI_HOME_DIR=$(SWI_HOME)
#  export SWI_HOME_DIR
endif

