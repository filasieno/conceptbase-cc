# Korrektur der MAKEFLAGS fuer unterschiedliche Make-Versionen
ifeq "$(CB_VARIANT)" "windows"   # make 3.79.1
	NEWFLAGS:=$(subst --unix,,$(MAKEFLAGS))
	NEWFLAGS2:=$(subst --,,$(NEWFLAGS))
	RESTFLAGS:=$(filter-out re,$(NEWFLAGS2))
	override MAKEFLAGS=re $(RESTFLAGS)
else
	ifeq "$(findstring -re,$(MAKEFLAGS))" "-re"
	RESTFLAGS:=$(filter-out -re,$(MAKEFLAGS))
	override MAKEFLAGS=re $(RESTFLAGS)
	endif

	ifeq "$(findstring -wre,$(MAKEFLAGS))" "-wre"
	RESTFLAGS:=$(filter-out -wre,$(MAKEFLAGS))
	override MAKEFLAGS=wre $(RESTFLAGS)
	endif

	# Fuer Make 3.75
	NEWFLAGS:=$(subst --,,$(MAKEFLAGS))
	override MAKEFLAGS=$(NEWFLAGS)
endif

