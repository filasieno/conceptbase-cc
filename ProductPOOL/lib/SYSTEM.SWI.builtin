/************************************************************************/
/**  DIV                                                               **/
/**  computes r1 / r2                                                  **/
/************************************************************************/

compute_DIV(_res,_r1expr,_,_r2expr,_) :-
	'Literals':evalFunctionArg(_r1expr,_r1id),  /** r1,r2 can be query calls ! **/
	'Literals':evalFunctionArg(_r2expr,_r2id),
	ground(_r1id),
	ground(_r2id),
	'GeneralUtilities':id2name(_r1id,_r1atom),
	'GeneralUtilities':id2name(_r2id,_r2atom),
	term_to_atom(_r1,_r1atom),
	term_to_atom(_r2,_r2atom),
	number(_r1),number(_r2),
        'GeneralUtilities':saveDIV(_rres,_r1,_r2),
	term_to_atom(_rres,_resatom),
	'FragmentToPropositions':create_if_builtin_object(_resatom,'Real',_res),
	!.


/************************************************************************/
/**  IDIV (INTEGER DIVISION)                                           **/
/**  computes truncate(r1 / r2)                                        **/
/************************************************************************/

compute_IDIV(_res,_r1expr,_,_r2expr,_) :-
        'Literals':evalFunctionArg(_r1expr,_r1id),  /** r1,r2 can be query calls ! **/
        'Literals':evalFunctionArg(_r2expr,_r2id),
        ground(_r1id),
        ground(_r2id),
        'GeneralUtilities':id2name(_r1id,_r1atom),
        'GeneralUtilities':id2name(_r2id,_r2atom),
        term_to_atom(_r1,_r1atom),
        term_to_atom(_r2,_r2atom),
	number(_r1),number(_r2),
        'GeneralUtilities':saveIDIV(_rres,_r1,_r2),
        term_to_atom(_rres,_resatom),
        'FragmentToPropositions':create_if_builtin_object(_resatom,'Integer',_res),
	!.


/************************************************************************/
/**  ConcatenateStrings                                                **/
/**  appends string s2 to the end of string s1                         **/
/************************************************************************/

compute_ConcatenateStrings(_res,_s1,_,_s2,_) :-
	ground(_s1),
	ground(_s2),
	'GeneralUtilities':id2name(_s1,_s1atom),
	'GeneralUtilities':id2name(_s2,_s2atom),
	atom_concat('"',_rs1,_s1atom),
	atom_concat(_ps1,'"',_rs1),
	atom_concat('"',_rs2,_s2atom),
	atom_concat(_ps2,'"',_rs2),
	'PrologCompatibility':pc_atomconcat(['"',_ps1,_ps2,'"'],_satom),
	'FragmentToPropositions':create_if_builtin_object(_satom,'String',_res),
	!.


compute_ConcatenateStrings3(_res,_s1,_,_s2,_,_s3,_) :-
	ground(_s1),
	ground(_s2),
	ground(_s3),
	'GeneralUtilities':id2name(_s1,_s1atom),
	'GeneralUtilities':id2name(_s2,_s2atom),
	'GeneralUtilities':id2name(_s3,_s3atom),
	atom_concat('"',_rs1,_s1atom),
	atom_concat(_ps1,'"',_rs1),
	atom_concat('"',_rs2,_s2atom),
	atom_concat(_ps2,'"',_rs2),
	atom_concat('"',_rs3,_s3atom),
	atom_concat(_ps3,'"',_rs3),
	'PrologCompatibility':pc_atomconcat(['"',_ps1,_ps2,_ps3,'"'],_satom),
	'FragmentToPropositions':create_if_builtin_object(_satom,'String',_res),
	!.

compute_ConcatenateStrings4(_res,_s1,_,_s2,_,_s3,_,_s4,_) :-
	ground(_s1),
	ground(_s2),
	ground(_s3),
	ground(_s4),
	'GeneralUtilities':id2name(_s1,_s1atom),
	'GeneralUtilities':id2name(_s2,_s2atom),
	'GeneralUtilities':id2name(_s3,_s3atom),
	'GeneralUtilities':id2name(_s4,_s4atom),
	atom_concat('"',_rs1,_s1atom),
	atom_concat(_ps1,'"',_rs1),
	atom_concat('"',_rs2,_s2atom),
	atom_concat(_ps2,'"',_rs2),
	atom_concat('"',_rs3,_s3atom),
	atom_concat(_ps3,'"',_rs3),
	atom_concat('"',_rs4,_s4atom),
	atom_concat(_ps4,'"',_rs4),
	'PrologCompatibility':pc_atomconcat(['"',_ps1,_ps2,_ps3,_ps4,'"'],_satom),
	'FragmentToPropositions':create_if_builtin_object(_satom,'String',_res),
	!.

/************************************************************************/
/**  StringToLabel                                                     **/
/**  removes the quotes of the string and returns it as label (no oid) **/
/************************************************************************/
compute_StringToLabel(_res,_s,_) :-
	ground(_s),
	'GeneralUtilities':id2name(_s,_satom),
	atom_concat('"',_rs,_satom),
	atom_concat(_res,'"',_rs),
	!.

/* ********************************************************************** */
/* Predicates for Java CBEditor, used by AnswerFormat CBGraphEditorResult */
/* ********************************************************************** */
buildCBEditorResult(_result,_object,_dst,_cat,_pal,_dir) :-
    parseObjectNames([_object,_dst,_cat,_pal],[_oid,_dstid,_catid,_palid]),
    !,
    replaceSpecialCharacter(_object,_object2),
    !,
    'ExternalCodeLoader':appendBuffer(_result,'  <object>\n    <name>'),
    'ExternalCodeLoader':appendBuffer(_result,_object2),
    'ExternalCodeLoader':appendBuffer(_result,'</name>\n'),
    'GeneralUtilities':getGraphType([_result],_oid,_palid),
    !,
    getEdges(_oid,_dstid,_catid,_dir,_edgeIds),
    !,
    'ExternalCodeLoader':appendBuffer(_result,'    <edges>\n'),
    makeEdgesElement(_edgeIds,_palid,_result),
    !,
    'ExternalCodeLoader':appendBuffer(_result,'    </edges>\n  </object>\n').

buildCBEditorResultWithoutEdges(_result,_object,_pal) :-
    parseObjectNames([_object,_pal],[_oid,_palid]),
    !,
    replaceSpecialCharacter(_object,_object2),
    !,
    'ExternalCodeLoader':appendBuffer(_result,'  <object>\n    <name>'),
    'ExternalCodeLoader':appendBuffer(_result,_object2),
    'ExternalCodeLoader':appendBuffer(_result,'</name>\n'),
    'GeneralUtilities':getGraphType([_result],_oid,_palid),
    !,
    'ExternalCodeLoader':appendBuffer(_result,'  </object>\n').

parseObjectNames(_atomlist,_idlist) :-
    atomconcatWithCommata(_atomlist,_bigatom),
    'PrologCompatibility':pc_stringtoatom(_Objstring,_bigatom),
    'TellAndAsk':ObjNameStringToList(_Objstring,_sml_objnamelist),
    'SelectExpressions':evalClassList(_sml_objnamelist,replaceSelectExpression,_idlist1),
    'TellAndAsk':EliminateClassInList(_idlist1,_idlist),
    !.


atomconcatWithCommata([],'') :- !.
atomconcatWithCommata([_a],_a) :- !.
atomconcatWithCommata([_a|_r],_res) :-
    atomconcatWithCommata(_r,_ar),
    !,
    'PrologCompatibility':pc_atomconcat([_a,',',_ar],_res).

replaceSpecialCharacter(_object,_object) :-
    sub_atom(_object,_,_,_,'<').

replaceSpecialCharacter(_object,_newobject) :-
    atom_chars(_object,_list),
    'GeneralUtilities':replace('<',_list,'&lt;',_newlist),
    'PrologCompatibility':pc_atomconcat(_newlist,_newobject),
    !.


getEdges(_oid,_dstid,_catid,dst,_edges) :-
    'GeneralUtilities':save_setof(_e,
        (_l)^('Literals':prove_literal('P'(_e,_oid,_l,_dstid)),
         'Literals':prove_literal('In'(_e,_catid))),
        _edges).

getEdges(_oid,_srcid,_catid,src,_edges) :-
    'GeneralUtilities':save_setof(_e,
        (_l)^('Literals':prove_literal('P'(_e,_srcid,_l,_oid)),
         'Literals':prove_literal('In'(_e,_catid))),
        _edges).

makeEdgesElement([],_,'') :- !.

makeEdgesElement([],_,_elem) :- !.

makeEdgesElement([_id|_r],_palid,_elem) :-
    'ScanFormatUtilities':outObjectName(_id,_object),
    replaceSpecialCharacter(_object,_object2),
    'ExternalCodeLoader':appendBuffer(_elem,'      <object>\n        <name>'),
    'ExternalCodeLoader':appendBuffer(_elem,_object2),
    'ExternalCodeLoader':appendBuffer(_elem,'</name>\n'),
    'GeneralUtilities':getGraphType([_elem],_id,_palid),
    'ExternalCodeLoader':appendBuffer(_elem,'      </object>\n'),
    makeEdgesElement(_r,_palid,_elem).


/* ********************************************************************** */
/* Extensions for ECA rule (predicates to be invoked in DO part)          */
/* ********************************************************************** */

/* ticket 151: auxiliary predicate required to protect access to ConceptBase 
   modules
*/
currentUser(_u) :-
   'CBserverInterface':active_user(_uname),
   'GeneralUtilities':name2id(_uname,_u),
   !.

