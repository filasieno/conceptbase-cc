# Wurzel des Pool-Verzeichnis relativ zum aktuellen Verzeichnis
POOL_ROOT=..

# Namen der Makefiles 
CONFIG_MK=$(word 1,$(wildcard $(POOL_ROOT)/config.mk $(POOL_ROOT)/src/config.mk))
RULES_MK=$(word 1,$(wildcard $(POOL_ROOT)/rules.mk $(POOL_ROOT)/src/rules.mk))


# Hole zuerst die globalen Variablen aus config.mk
include $(CONFIG_MK)


#---------------------------------------
# Lokale Variablen
#---------------------------------------
# Alle SubDirectories
SubDirs=

# Aktuelles Verzeichnis relativ zur POOL-Wurzel (endet mit /)
CurrDir=lib/

# Die Sourcen
MK_SOURCES=Makefile

# Targets
TARGETS=


# Dateien, die nach EXPORT kopiert werden sollen
EXPORTFILES=SYSTEM.ecarule SYSTEM.rule SYSTEM.ruleinfo SYSTEM.symbol SYSTEM.telos \
   SYSTEM.SWI.ecarule SYSTEM.SWI.rule SYSTEM.SWI.ruleinfo SYSTEM.SWI.symbol SYSTEM.SWI.telos cbiva-logo.png \
   cbiva-logo.ico cbgraph-logo.png cbgraph-logo.ico application-x-cbgraphfile.svg cbgraph-mime.xml


# Kurze Beschreibung der Komponente
INFO_TXT=Verzeichnis fuer die SYSTEM-Dateien von ConceptBase
	

#---------------------------------------
# Lokale Regeln
#---------------------------------------
# Make in allen Subdirectories aufrufen
all: $(MAKE_DIRS) $(TARGETS)


#---------------------------------------
# Nun die globalen Regeln
#---------------------------------------
include $(RULES_MK)

