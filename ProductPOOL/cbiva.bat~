@echo off

rem *** Trick to have the CMD window executing this batch file minimized
if not "%minimized%"=="" goto :runminimized
set minimized=true
start /min cmd /C "%~dpnx0 %*"
goto :EOF
:runminimized

SETLOCAL


rem *** If you installed ConceptBase to a different directory, then adapt CB_HOME
rem *** Avoid directory names with blanks or other special characters!
if not defined CB_HOME set CB_HOME=c:\conceptbase

cd %CB_HOME%

if exist "%programfiles%\Java" goto :java_default
if exist "jre1.6.0_07\bin\javaw.exe" goto :java_local



rem *** default java found via search path
:java_default
start /b java -DCB_HOME="%CB_HOME%" -jar "%CB_HOME%"\lib\classes\cb.jar
goto :alldone


rem *** local java found
:java_local
start /b jre1.6.0_07\bin\javaw.exe -DCB_HOME="%CB_HOME%" -jar "%CB_HOME%"\lib\classes\cb.jar
goto :alldone




