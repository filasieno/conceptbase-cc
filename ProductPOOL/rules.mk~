	cd $(OBJDIR) ;\
	$(LATEX2HTML) -no_images -dir `pwd`/html $(notdir $<) ;\
	$(LATEX2HTML) -images_only -dir `pwd`/html $(notdir $<) ;\
	$(RM) $(notdir $<)

html: $(HTML_OBJECTS)

clean_html:
	/bin/rm -rf $(HTML_DIR) $(EXPDIR)/html


