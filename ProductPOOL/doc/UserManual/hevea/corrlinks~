# correct URLS representation generated by hevea
# sed syntax following http://www.grymoire.com/Unix/Sed.html
# 
# Hevea just uses the character following the URL as the anchor label.
# We rewrite is such a way that the label 'link' is used. 
# The first substitution transfomed the ConceptBase logo to a URL pointing
# to ConceptBase.cc
# The other rules are for the cases .,(,),[,t,f. These are all the characters
# following a URL in the ConceptBase.cc user manual.
# (c) M. Jeusfeld, 2013-11-14
#
mv cbm.html cbm-temp.html
sed -e "1,100s~<img src=\"cbm002.png\">~<a href=\"http://conceptbase.cc\"><img src=\"cbm002.png\" alt=\"ConceptBase.cc\"></a>~g
s~>\.</a>~>link</a>\.~g
s~>(</a>~>link</a>(~g
s~>)</a>~>link</a>)~g
s~>\]</a>~>link</a>\]~g
s~>:</a>~>link</a>:~g
s~>t</a>~>link</a> t~g
s~>s</a>~>link</a> s~g
s~>a</a>~>link</a> a~g
s~>c</a>~>link</a> c~g
s~>u</a>~>link</a> u~g
s~>I</a>~>link</a> I~g
s~>f</a>~>link</a> f~g
s~>,</a>~>link</a>,~g
s~>;</a>~>link</a>;~g
s~>i</a>~>link</a> i~g"  cbm-temp.html > cbm.html






