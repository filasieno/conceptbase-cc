/* arExpr stands for is either e1+e2, or e1-e2, or a funcExpr */

/* Grammar used fo arithmetic expressions (adapted from 
     http://www.fh-wedel.de/~si/vorlesungen/cb/SyntaxAnalyse/LLAnalyse.html
   The epsilon productions are removed for allowing easier implementation of
   the synthetic attributes makeAddition/makeMultiplication

G = (N, T, P, S)
N :	{ S, E, E', T, T', F }
T :	{ (, ), *, +, -, /, id, num, $ }
S :	S
P :	S	::=	E $
 	E	::=	T E'
 	E	::=	T
 	E'	::=	+ T E'
 	E'	::=	- T E'
 	E'	::=	+ T
 	E'	::=	- T
 	T	::=	F T'
 	T'	::=	* F T'
 	T'	::=	/ F T'
 	T'	::=	* F
 	T'	::=	/ F
 	F	::=	( E )
 	F	::=	id
 	F	::=	num

The non-terminal symbols correspont to the DCG predicates as follows:

E : arExpr
E': arAddExpr
T : arTerm
T': arMultTerm
F : arFactor

*/


arExpr(_expr) ==>
