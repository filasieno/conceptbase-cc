/** These rules process the parsing of rules **/
/** Incorrect rules are rejected **/

/** baue aus einer Tokenliste eine Constraint **/
buildMSFOLconstraint('MSFOLconstraint'(_t)) ==>
               parseDecl(_t),
               where[!].


buildAssertionRule('MSFOLrule'(_conclvars,_condition, _conclusion)) ==>
	foralls(_vtypes,_termlist),
	where['VarTabLookup_vars'(_conclvars)],
	buildAssertionRule2(_cond,_conclusion),
	where[!,
    	  ((_termlist == [] , _condition = _cond);
		   (_termlist \== [], append(_termlist,[_cond],_cond2), _condition = and(_cond2))
		  ),
		  validConclusion(_conclusion,_conclvars)].

/* Ticket 206: we only have one rule to parse MSFOLrules; the two cases are taken care by splitRule */
buildAssertionRule2(_condition, _conclusion) ==>
        exp(_restformula),
        where [!,splitRule(_restformula,_condition,_conclusion)].


buildAssertionTerm('MSFOLassertion'(_t)) ==>
               parseDecl(_t),
               where[!].


buildAssertionTerm('MSFOLassertion'(_t)) ==>
		exp(_t),
		where [ ! ].



shortConclusion(lit(_concl)) ==>
	lit(_concl).

shortConclusion(lit(_concl)) ==>
