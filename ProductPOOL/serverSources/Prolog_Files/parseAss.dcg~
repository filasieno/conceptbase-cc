/* non-backtracking rules for litarglist: */

/* this is for a non-empty list of litargs */
litarglist([_first|_rest]) ==>
 	litarg(_first),
	litarglist_rest(_rest).

/* litarglist_rest is for a potentially empty list of litargs */
/* case1: a comma means that at least one litarg will follow, i.e. a non-empty list */
litarglist_rest(_list) ==>
        [','],
        where[!],
	litarglist(_list).

/* no comma: no more args! */
litarglist_rest([]) ==>
        where[!].


/******************************/
/** Arguments eines Literals **/
/******************************/


/* literal arguments excluding arithmetic expressions */
litarg(_arg) ==> constantval(_arg).
litarg(_arg) ==> deriveExpression(_arg).
litarg(_arg) ==> selectExpression(_arg).
litarg(_arg) ==> variableOrObject(_arg).


/* literal arguments including arithmetic expressions */
litarg1(_arg) ==> constantval(_arg).
litarg1(_arg) ==> arExpr(_arg).
litarg1(_arg) ==> deriveExpression(_arg).
litarg1(_arg) ==> selectExpression(_arg).
litarg1(_arg) ==> variableOrObject(_arg).  /* must be the last clause because it also begins with a ident(_) */


/** possible types of a variable, ticket #316: we specifically exclude function calls like F(x,...)
*   as possible variable types. Use the long syntax like F[x/param,..] when such a variable type 
*   is needed
**/

typeExpr(_arg) ==> constantval(_arg).  /* in particular object names in double quotes */
typeExpr(_arg) ==> regularDeriveExpression(_arg).
typeExpr(_arg) ==> shortQueryCall(_arg).  /* e.g. Interval[1,100] */
typeExpr(_arg) ==> selectExpression(_arg).
typeExpr(_arg) ==> typename(_arg). /* like objectname but we generate error messages when arg is not an objectname */



/** Das Argument eines Literals ist eine Variable oder eine Konstante,
* die fuer ein Objekt steht. Wenn _arg eine Konstante ist, muss sie an dieser
* Stelle durch die entsprechende OID ersetzt werden.
* Dies geschieht in der where-Klausel. **/

/** 17-Feb-2005/M.Jeusfeld: include a '!' to prevent silly error messages **/
/** caused by backtracking on litarg.                                     **/

variableOrObject(_arg) ==>                                        /* 31-Oct-1995 LWEB */
        [ident(_x)],
        /** these keywords are never a literal argument: **/
        where [ \+ memberchk(_x,['Known','new','UNIFIES','in','isA','not','In',
                                 'forall','exists','IDENTICAL','Ai'])],   
        where[ (
               (isVariable(_x,_arg),!);
               (temp_msp(_m),t_name2id(_m,_x,_arg),!);   /**  the '!' here is new **/
               (report_error('PFNFE',parseAss_dcg,[_x]),
                pc_atomconcat('%%UNKNOWN--',_x,_arg),!)
               )
             ].

/* for convertSelectExpression */
objectname(_arg) ==>                                       
        [ident(_x)],
        where [ \+ memberchk(_x,['Known','new','UNIFIES','in','isA','not','In',
                                 'forall','exists','IDENTICAL','Ai']), 
                temp_msp(_m),t_name2id(_m,_x,_arg),!
             ].

typename(_arg) ==>                                       
        [ident(_x)],
        where [ (
