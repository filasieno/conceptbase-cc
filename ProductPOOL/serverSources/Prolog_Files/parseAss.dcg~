	lit(_concl),
	[')'].


parseDecl(_t) ==>
               exp(_t),
               where[!].


exp(_t) ==>
       elemexp(_t1),
       andexp(_t1,_t2),
       orexp(_t2,_t3),
       implexp(_t3,_t4),
       equivexp(_t4,_t),
       where[!].

elemexp(_forallTree) ==>
	[ident(forall)],
    vartypelist(_vtypes,_termlist),
	where[((_termlist == [],
		   expandQuantifier(forall,_vtypes,_r, _forallTree)
		   );
		   (_termlist \== [],
		    append(_termlist,[_r],_r2),
		    expandQuantifier(forall,_vtypes,and(_r2), _forallTree)
		   )
		  )],
    exp(_r).

elemexp(_existsTree) ==>
    [ident(exists)],
    vartypelist(_vtypes,_termlist),
	where[((_termlist == [],
		   expandQuantifier(exists,_vtypes,_r, _existsTree)
		   );
		   (_termlist \== [],
		    append(_termlist,[_r],_r2),
		    expandQuantifier(exists,_vtypes,and(_r2), _existsTree)
		   )
		  )],
    exp(_r).

elemexp(not(_t)) ==>
       [ident('not')],
       elemexp(_t).

elemexp(_t) ==>
       ['('],
       exp(_t),
       [')'].

/* one position lower */
elemexp(lit(_l)) ==>
       lit(_l).

elemexp(_t) ==>         /* 19-5-95/CQ: SelectExpB mit in,isA,== sind ebenfalls elementare Expressions */
	elemSelectExpB(_t).

vartypelist([_type|_rest],_termlist) ==>
	vartype(_type,_term),
	optvartypelist(_rest,_termlist2),
	where[!,append(_term,_termlist2,_termlist)].

optvartypelist(_typelist,_termlist) ==>
	vartypelist(_typelist,_termlist).

optvartypelist([],[]) ==> where[true,!].

/** Eine Variable kann auch ueber einen Select-Ausdruck von Typ B quantifiziert
 * werden 1-3-95/CQ **/
vartype(vtype(_vlist,_t),_termlist) ==>
	varlist(_vlist),
	['/'],
	selectexpb(_b),
	where[replaceSelectExpBList(_b,_vlist,_t,_termlist),
		  'VarTabInsert'(_vlist,[_t])].

/** Eine Variable kann auch in mehreren Klassen sein.
 * Deshalb bietet es sich an, diese Klassen als Liste zu bewaren. **/
vartype(vtype(_vars,_ts),[]) ==>
	varlist(_vars),
	['/'],
	['['],
	typelist(_ts),
	[']'],
	where['VarTabInsert'(_vars,_ts),!,containsNoReservedWord(_vars)].

vartype(vtype(_vars,_t),[]) ==>
	varlist(_vars),
	['/'],
	type(_t),
	where['VarTabInsert'(_vars,[_t]),!,containsNoReservedWord(_vars)].




varlist([_v|_rest]) ==>
	[ident(_v)],
	[','],
	varlist(_rest),
	where [!,_v \== '~this'].

varlist([_v]) ==>
	[ident(_v)],
	where[!,_v \== '~this'].

/** The notion of andexp is to build from input t1 and t2 and ... and tn a tree
* of the form and([t1,t2,...,tn]). I must gather t1..tn in a help list first
* that must have a distinct name (and_h) from the final expression.
* Otherwise  there are cases in which the reverse-case can be accidentially
* applied. **/

/** Found another and-item **/
andexp(and_h(_ts),_t1) ==>
       [ident(and)],
       elemexp(_t2),
       andexp(and_h([_t2|_ts]),_t1).

/** Starting with the first subtree _t1 **/
andexp(_t1,_t2) ==>
       [ident(and)],
       elemexp(_t3),
       andexp(and_h([_t3,_t1]),_t2).

/** no other and items; reverse the list of subtrees to regain the
*  original sequence **/
andexp(and_h(_t1),and(_t2)) ==>
       where[reverse(_t1,_t2)].

/** last case: simply do nothing **/
andexp(_t1,_t2) ==>
       where[_t2 = _t1].


/** Now apply the same idea to or-expressions: note that 'and' has a
* higher priority than 'or' **/

orexp(or_h(_ts),_t2) ==>
       [ident(or)],
       elemexp(_t3),
       andexp(_t3,_t4),
       orexp(or_h([_t4|_ts]),_t2).

orexp(_t1,_t2) ==>
       [ident(or)],
       elemexp(_t3),
       andexp(_t3,_t4),
       orexp(or_h([_t4,_t1]),_t2).

orexp(or_h(_t1),or(_t2)) ==>
       where[reverse(_t1,_t2)].

orexp(_t1,_t2) ==>
       where[_t2 = _t1].

implexp(_t1,_t2) ==>
       ['==>'],
       elemexp(_t3),
       andexp(_t3,_t4),
       orexp(_t4,_t5),
       implexp(impl(_t1,_t5),_t2).

implexp(_t1,_t2) ==>
       where[_t2 = _t1].

equivexp(_t1,_t2) ==>
	['<==>'],
	elemexp(_t3),
	andexp(_t3,_t4),
	orexp(_t4,_t5),
	implexp(_t5,_t6),
	equivexp(and([impl(_t1,_t6),impl(_t6,_t1)]),_t2).

equivexp(_t1,_t2) ==>
	where[_t2 = _t1].


