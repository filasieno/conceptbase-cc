{***********************************************************}
#MODE(build_with_for_view(i,i,o,o))

build_with_for_view([],[],[],[]).

build_with_for_view([_label,_value|_arglist],
			[r(_attrcat)|_argexp],
			[attrdecl([_attrcat],[property(_label,_name)])|_rattrdecl],
			_substlist) :-
