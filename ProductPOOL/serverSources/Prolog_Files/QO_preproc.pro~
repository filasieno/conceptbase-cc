{================= preOptimize   =====================================*}

{*--------------------------------------------------------------------*}
{*                                                                    *}
{* preOptimize:                                                       *}
{* Vorbereitende Optimierung der Datalog-Regeln:                      *}
{*                                                                    *}
{* * abschliessende A -> Adot Ersetzung                               *}
{* * Minimierung der Argumentlisten                                   *}
{*                                                                    *}
{*--------------------------------------------------------------------*}
#MODE( preOptimize(i,i,o))

preOptimize(_ruleSetIn,_ranges,_ruleSet) :-

	{* 1. speichern der beim parsen erzeugten Variablentabelle *}
	removeRFVartab,
	storeRFVartab(_ranges),

	{* 2. abschliessende semantische Optimierung *}
	semOptDatalogList(_ruleSetIn,_ruleSetOut1),


	{* 3. Minimierung der Argumentlisten         *}
	fixMinArgRuleSet(_ruleSetOut1,_ruleSet),!.





{================= semOpt_Datalog ====================================*}

semOptDatalogList([],[]).
semOptDatalogList([(_head :- _ruleTerm)|_ruleSetIn],[(_head :- _newRuleTerm)|_ruleSet]) :-
	Conjunct2List(_ruleTerm,_lits0),
	semOpt_Datalog(_lits0,_lits1),
	List2Conjunct(_lits1,_newRuleTerm),
	semOptDatalogList(_ruleSetIn,_ruleSet).


{*--------------------------------------------------------------------*}
{* 	semOpt_Datalog                        			      *}
{*	   1. A nach Adot:                                 	      *}
{*		Auf Datalog-Ebene wird eine abschliessende 	      *}
{*		Ersetzung von A-Literalen durch Adot-Literale	      *}
{*		durchgefuehrt					      *}
{*         2. In-Literale entfernen				      *}
{*		In-Literale, die redundante Klassenbindungen 	      *}
{*		enthalten, werden entfernt			      *}
{*								      *}
{*--------------------------------------------------------------------*}
#MODE( semOpt_Datalog(i,o))

semOpt_Datalog(_litsIn,_litsOut) :-

	{* Klassen bestimmen *}
	getConstAndVarsList(_litsIn,_const,_vars),
	getInLitsWithConstClass(_litsIn,_const,_inLits),
	getVarClassesInRFVT(_vars,_inLits,_varsWithClasses),

	{* Schritt 1: A nach Adot-Ersetzung *}
	replaceAsWithAdots(_litsIn,_const,_varsWithClasses,_litsOut1),

	{* Schritt 2: Redundante In-Literale entfernen *}
	removeRedundantInLitsForFunctions(_litsOut1,_litsOut1,_litsOut2),
	removeRedundantInLits(_litsOut2,_vars,_litsOut),
    !.

semOpt_Datalog(_lits,_lits).

{*--------------------------------------------------------------------*}
{*								      *}
{* Finde die In-Literale, mit konstanter Klasse, die noch verblieben  *}
{* sind.		      					      *}
{*								      *}
{*--------------------------------------------------------------------*}
#MODE( getInLitsWithConstClass(i,o))

getInLitsWithConstClass([],_,[]).
getInLitsWithConstClass([In(_x,_c)|_lits],_const,[In(_x,_c)|_inLits]) :-
	memberchk(_c,_const),
	!,
	getInLitsWithConstClass(_lits,_const,_inLits).
getInLitsWithConstClass([_|_lits],_const,_inLits) :-
	getInLitsWithConstClass(_lits,_const,_inLits).


{*--------------------------------------------------------------------*}
{*								      *}
{* getVarClassesInRFVT						      *}
{* Bestimme die Klassen der Variablen in der Literalsequenz aus der   *}
{* vom Parser erzeugten Variablentabelle und den in der Sequenz       *}
{* verbliebenen In-Literalen.					      *}
{*								      *}
{*--------------------------------------------------------------------*}
getVarClassesInRFVT(_vars,_inLits,_varClasses) :-
	initVCList(_vars,_vcList0),
	updateVCListRFVT(_vcList0,_vcList1),
	updateVCListIn(_inLits,_vcList1,_varClasses).



{*--------------------------------------------------------------------*}
{*								      *}
{* getVarClassesAdot						      *}
{* Bestimme die Klassen der Variablen nur aus den Klassenbindungen,   *}
{* die sich aus den Adot-Literalen ergeben, um redundante In-Literale *}
{* zu entdecken              					      *}
{*								      *}
{*--------------------------------------------------------------------*}
getVarClassesAdot(_vars,_lits,_varClasses) :-
	initVCList(_vars,_vcList0),
	updateVCListAdot(_lits,_vcList0,_varClasses).



{*--------------------------------------------------------------------*}
{*								      *}
{* initVCList       						      *}
{* Eingabe: Liste von Variablen                                       *}
{* Ausgabe: Liste mit Elementen der Form _var-_classList              *}
{*          In _classList werden die Klassen von _var gesammelt	      *}
{*	    Diese Liste wird hier initialisiert 		      *}
{*--------------------------------------------------------------------*}
#MODE( initVCList(i,o))

initVCList([],[]).
initVCList([_var|_vars],[_var-[]|_vcList]) :-
	initVCList(_vars,_vcList).




#MODE( updateVCListRFVT(i,o))

updateVCListRFVT([],[]).
updateVCListRFVT([_c-_classes|_vcs],[_c-_newClasses|_newVcs]) :-
	getClassesFromRFVT(_c,_rfClasses),
	append(_rfClasses,_classes,_newClasses),
	updateVCListRFVT(_vcs,_newVcs).


{*--------------------------------------------------------------------*}
{*								      *}
{* updateVCListIn						      *}
{* Eingabe: Liste von Paaren _var-_classlist                          *}
{*	    Liste von Literalen 				      *}
{* Ausgabe: Tritt ein Literal In(_x,c) in der Literalliste auf, wobei *}
{*          c konstant und _x eine Variable, so wird c in die Liste   *}
{*	    der Klassen von _x aufgenommen      		      *}
{*--------------------------------------------------------------------*}
#MODE( updateVCListIn(i,i,o))

updateVCListIn([],_vcList,_vcList).

updateVCListIn([In(_x,_c)|_ins],_vcListIn,_vcList) :-
	isConst(_c),!,
	select(_x-_classes,_vcListIn,_vcListRem),
	updateVCListIn(_ins,[_x-[_c|_classes]|_vcListRem],_vcList).

updateVCListIn([In(_x,_c)|_ins],_vcListIn,_vcList) :-
	updateVCListIn(_ins,_vcListIn,_vcList).


{*--------------------------------------------------------------------*}
{*								      *}
{* updateVCListAdot						      *}
{* Eingabe: Liste von Paaren _var-_classlist                          *}
{*	    Liste von Literalen 				      *}
{* Ausgabe: Tritt ein Literal Adot(p,_x,_y) auf, so wird fuer r       *}
{*          _x (_y) die Quellklasse (Zielklasse) der Attributkategorie*}
{*	    in die Liste der Klassen aufgenommen. 		      *}
{*--------------------------------------------------------------------*}
#MODE( updateVCListAdot(i,i,o))

updateVCListAdot([],_vcList,_vcList).

updateVCListAdot([Adot(_c,_x,_y)|_lits],_vcListIn,_vcList) :-
	isConst(_l),!,
	getSource(_c,_s),getDest(_c,_d),
	(
		(
			isVar(_x),
	  		select(_x-_classesX,_vcListIn,_vcListRem1),
	  		_vcList1 = [_x-[_s|_classesX]|_vcListRem1]
		);
	 	(
			isConst(_x),_vcList1 = _vcListIn)
	),
	(
		(
			isVar(_y),
          		select(_y-_classesY,_vcList1,_vcListRem2),
          		_vcList2 = [_y-[_d|_classesY]|_vcListRem2]
		);
         	(
			isConst(_y),_vcList2 = _vcList1
		)
	),
	updateVCListAdot(_lits,_vcList2,_vcList).

updateVCListAdot([_|_lits],_vcListIn,_vcList) :-
	updateVCListAdot(_lits,_vcListIn,_vcList).




{* ------------------------------------------------------------------ *}
{* replaceAsWithAdots						      *}
{* Eingabe: Literalsequenz 					      *}
{*	    Liste der Konstanten				      *}
{*	    Liste der Variablen mit ihre Klassen		      *}
{* Ausgabe: Literalsequenz, in der A-Literale (wenn moeglich) durch   *}
{*	    Adot-Literale ersetzt sind                                *}
{*								      *}
{* ------------------------------------------------------------------ *}
#MODE( replaceAsWithAdots(i,i,i,o))

replaceAsWithAdots([],_,_,[]).

replaceAsWithAdots([A(_x,_l,_y)|_lits],_const,_varsWithClasses,[Adot(_cc,_x,_y)|_newLits]) :-
	{* Label muss konstant sein *}
	memberchk(_l,_const),

	{* Alle Objekte mit Label _l finden *}
	findall(_ccCand,(qo_prove_literal(Label(_ccCand,_l))),_ccList),

	{* Die moeglichen concernedClasses herausfinden *}
	filterConcernedClass(A(_x,_l,_y),_ccList,_const,_varsWithClasses,_ccListTemp),
	_ccListTemp \== [],
	_ccListTemp = [_ccCand|_otherCCs],!,

	{* die speziellste ConcernedClass wird gewaehlt *}
	findMostSpecialAttrCat(_otherCCs,_ccCand,_cc),
	replaceAsWithAdots(_lits,_const,_varsWithClasses,_newLits).

replaceAsWithAdots([_lit|_lits],_const,_vars,[_lit|_newLits]) :-
        acceptableInQueryConstraint(_lit),   {* 24-Jun-2004/M.Jeusfeld *}
	replaceAsWithAdots(_lits,_const,_vars,_newLits).


{* 24-Jun-2004/M.Jeusfeld *}
{* We normally do not tolerate a literal A(x,m,y) in the COMPILED code for a *}
{* query constraint (like we don't accept it for other formulas). However,   *}
{* if the flag forceConcernedClass is switched off, we still accept it for   *}
{* backward compatibility with older ConceptBase versions.                   *}


acceptableInQueryConstraint(A(_x,_m,_y)) :-
  get_cb_feature(forceConcernedClass,'strict'),
  increment('error_number@F2P'),
  !,
  fail.


acceptableInQueryConstraint(_lit).


{* ------------------------------------------------------------------ *}
{* 								      *}
{* filterConcernedClass:     					      *}
{* fuer die Menge der Attribute mit gegebenem Label wird getestet,    *}
{* ob sie als concerned Class in Betracht kommen		      *}
{*								      *}
{* ------------------------------------------------------------------ *}
#MODE( filterConcernedClass(i,i,i,i,o))

filterConcernedClass(_,[],_,_,[]).

filterConcernedClass(A(_x,_l,_y),[_cc|_ccCands],_const,_varsWithClasses,[_cc|_ccList]) :-

	{* Quellklasse lesen *}
	getSource(_cc,_sc),
	(
		(
			{* _x ist Konstante und SourceKlasse ist eine Klasse
			   von _x
			*}
	 		memberchk(_x,_const),
			qo_prove_literal(In(_x,_sc))
		);
		(
			{* _x   ist Variable und Source-Klasse ist eine Klasse von _x
				oder eine Spezialisierung/Generalisierung einer dieser
				Klassen
			*}
			select(_x-_classesX,_varsWithClasses,_),
			(
				(memberchk(_sc,_classesX));
				(listContainsRealSubClass(_sc,_classesX));
				(listContainsRealSuperClass(_sc,_classesX))
			),!
		)
	),

	{* Zielklasse: analoges Vorgehen *}
	getDest(_cc,_dc),
	(
		(
			{* _y ist Konstante und SourceKlasse ist eine Klasse
			   von _y
			*}
	 		memberchk(_y,_const),
			qo_prove_literal(In(_y,_dc))
		);
		(
			{* _y   ist Variable und Dest-Klasse ist eine Klasse von _x
				oder eine Spezialisierung/Generalisierung
				einer dieser Klassen
			*}
			select(_y-_classesY,_varsWithClasses,_),
			(
				(memberchk(_dc,_classesY));
				(listContainsRealSubClass(_dc,_classesY));
				(listContainsRealSuperClass(_dc,_classesY))
			),!
		)
	),!,
	filterConcernedClass(A(_x,_l,_y),_ccCands,_const,_varsWithClasses,_ccList).

filterConcernedClass(A(_x,_l,_y),[_|_ccCands],_const,_vars,_ccList) :-
	filterConcernedClass(A(_x,_l,_y),_ccCands,_const,_vars,_ccList).


{*******************************************************************}
{                                                                   }
{ removeRedundantInLitsForFunctions(_lits,_alllits,_olits)          }
{                                                                   }
{ Description of arguments:                                         }
{    lits : Liste der noch zu betrachtenen Literale                 }
{ alllits : Liste aller Literale dieser Regel                       }
{   olits : Reduzierte Liste ohne redundante Literale               }
{                                                                   }
{ Description of predicate:                                         }
{  Entfernt In-Literale fuer Variablen die als Ergebnis einer       }
{  Funktion auftauchen.                                             }
{*******************************************************************}

#MODE((removeRedundantInLitsForFunctions(i,i,o)))


removeRedundantInLitsForFunctions([],_alllits,[]).

removeRedundantInLitsForFunctions([In(_x,_c)|_lits],_alllits,_olits) :-
	isConst(_c),
	pc_member(_lit,_lits),
	_lit =.. [_fid,_x|_args],
	id2name(_fid,_),
	name2id(Function,_funcid),
	prove_literal(In(_fid,_funcid)),
	!,
	removeRedundantInLitsForFunctions(_lits,_alllits,_olits).

removeRedundantInLitsForFunctions([_lit|_lits],_alllits,[_lit|_olits]) :-
	removeRedundantInLitsForFunctions(_lits,_alllits,_olits).



{* ------------------------------------------------------------------ *}
{* 								      *}
{* removeRedundantInLits     					      *}
{* Die durch die implizite Klassenbindung durch Adot-Literale         *}
{* redundant gewordenen In-Literale werden entfernt		      *}
{*								      *}
{* ------------------------------------------------------------------ *}
#MODE( removeRedundantInLits(i,i,o))

removeRedundantInLits(_litsIn,_vars,_litsOut) :-
	getVarClassesAdot(_vars,_litsIn,_varClasses),
	testRedundantIns(_litsIn,_varClasses,[],_litsOut).

#MODE( testRedundantIns(i,i,i,o))

testRedundantIns([],_,_,[]).

{ In-Literale fuer Label/TransactionTime entfernen }
testRedundantIns([In(_x,_c)|_lits],_varClasses,_rlits,_litsOut) :-
	isConst(_c),
	name2id(TransactionTime,_ttid),
	name2id(Label,_lid),
	(_c == _ttid; _c == _lid),
	!,
	testRedundantIns(_lits,_varClasses,_rlits,_litsOut).

testRedundantIns([In(_x,_c)|_lits],_varClasses,_rlits,_litsOut) :-
	isConst(_c),
	select(_x-_classes,_varClasses,_),
	listContainsSubClass(_c,_classes),!,
	testRedundantIns(_lits,_varClasses,_rlits,_litsOut).

testRedundantIns([In(_x,_c)|_lits],_varClasses,_rlits,_litsOut) :-
	isConst(_c),
	name2id(Proposition,_pid),
    _c == _pid,
    (pc_member(_l,_lits);pc_member(_l,_rlits)),
    _l =.. [_|_args],
	pc_member(_x,_args),
	!,
	testRedundantIns(_lits,_varClasses,_rlits,_litsOut).

testRedundantIns([_l|_lits],_varClasses,_rlits,[_l|_litsOut]) :-
	testRedundantIns(_lits,_varClasses,[_l|_rlits],_litsOut).



{================= fixMinArgs ========================================*}

{*--------------------------------------------------------------------*}
{* die an den Anfrageoptimierer uebergebene Regelmenge wird wie	      *}
{* folgt vorverarbeitet:                                    	      *}
{*			                                       	      *}
{* bei bestimmten intensional definiertern Literalen wird die Zahl der*}
{* Argumente minimiert. Im Regelkopf treten nur noch solche Argumente *}
{* auf, die in den Regelruempfen tatsaechlich verwendet werden.       *}
{* Grund: bei n Argumenten sind fuer 2^n verschiedene Belegungsmuster *}
{* die Kosten zu speichern.                                           *}
{*                                                                    *}
{*--------------------------------------------------------------------*}
#MODE( fixMinArgRuleSet(i,o))

fixMinArgRuleSet(_ruleSetIn,_ruleSetOut) :-
	buildRuleTermList(_ruleSetIn,_ruleTermList),
	fixMinArgList(_ruleTermList,_ruleTermListOut),
	ruleTermList2ConjunctList(_ruleTermListOut,_ruleSetOut).





{*--------------------------------------------------------------------*}
{*			                                       	      *}
{* buildRuleTermList:                                                 *}
{* die eingegebene Regelmenge wird in einen Liste von Termen der Form *}
{* rule(<Kopf-Literal>,<Regelrumpf>) zerlegt, wobei der Regelrumpf als*}
{* Liste von Literalen repraesentiert ist.                            *}
{*                                                                    *}
{*--------------------------------------------------------------------*}

#MODE( buildRuleTermList(i,o))

buildRuleTermList([],[]).
buildRuleTermList([(_head :- _tail)|_ruleSetIn],[rule(_head,_bodyLits)|_ruleTermList]) :-
	Conjunct2List(_tail,_bodyLits),
	buildRuleTermList(_ruleSetIn,_ruleTermList).

#MODE( ruleTermList2ConjunctList(i,o))

ruleTermList2ConjunctList([],[]).
ruleTermList2ConjunctList([rule(_head,_bodyLits)|_ruleTermList],[(_head :- _tail)|_ruleSetOut]) :-
	List2Conjunct(_bodyLits,_tail),
	ruleTermList2ConjunctList(_ruleTermList,_ruleSetOut).



{*--------------------------------------------------------------------*}
{*			                                       	      *}
{* minimizeArgumentList:                                              *}
{* in der eingegebenen Regelmenge sind die Argumentlisten der         *}
{* vom System erzeugten intensional definierten Literale nicht minimal*}
{* In den Argumentlisten treten nicht nur die Variablen auf, die in   *}
{* den verschiedenen Regelruempfen verwendet werden.                  *}
{*                                                                    *}
{* minimizeArgumentList reduziert die Argumente der Literale auf die  *}
{* die wirklich benoetigt werden.                                     *}
{*                                                                    *}
{* Dieses Praedikat darf nur auf die vom Anfrageuebersetzer           *}
{* erzeugten temporaeren Regeln angewendet werden. Weiterhin sollte   *}
{* sichergestellt sein, dass zumindest ein Argument bei jedem         *}
{* Literal uebrig bleibt.                                             *}
{*--------------------------------------------------------------------*}

testMinArgList :-
	_ruleList =
		[
		rule(a('_b','_c','_d'),[a('_a','_b','_c'),b('_a','_b','_d')]),
		rule(b('_a','_b','_c'),[a('_a','_b','_b')])
		],
	testMinArgList(_ruleList).

testMinArgList(_ruleListIn) :-
	minimizeArgumentList(_ruleListIn,_ruleList),
	_ruleList \== _ruleListIn,!,
	testMinArgList(_ruleList).
testMinArgList(_ruleList).


#MODE( fixMinArgList(i,o))

fixMinArgList(_ruleListIn,_ruleListOut) :-
	minimizeArgumentList(_ruleListIn,_ruleList),
	_ruleList \== _ruleListIn,!, {* Fixpunkt noch nicht erreicht *}
	fixMinArgList(_ruleList,_ruleListOut).
fixMinArgList(_ruleList,_ruleList).


#MODE( minimizeArgumentList(i,o))

minimizeArgumentList(_ruleListIn,_ruleListOut) :-
	buildArgumentMasks(_ruleListIn,_headMasks),
	checkArgumentsInRules(_ruleListIn,_headMasks,_ruleListOut).

{*--------------------------------------------------------------------*}
{*			                                       	      *}
{* buildArgumentMasks                                                 *}
{* fuer jedes Kopfliteral wird eine Maske bestimmt. Diese Liste       *}
{* enthaelt fuer jede Argumentposition eine "1", wenn das Argument    *}
{* benoetigt wird, ansonsten eine "0".                                *}
{*                                                                    *}
{* Zunaechst werden alle Regelruempfe eines Kopfliterals bestimmt.    *}
{* Tritt eine Variable aus dem Regelkopf in einem Regelrumpf auf, so  *}
{* wird sie benoetigt. Tritt sie nicht auf, so hat sie keinen Einfluss*}
{* auf das Berechnungsergebnis.                                       *}
{*                                                                    *}
{* Zwei Faelle muessen unterschieden werden:                          *}
{* a) gibt es neben den Regeln in der uebergebenen Regelmenge weitere *}
{*    Regeln, in denen das Kopfliteral im Rumpf auftreten kann, so    *}
{*    darf seine Stelligkeit nicht veraendert werden. Beispiele:      *}
{*    In-Literale, Adot-Literale, Top-Level Literale von queries      *}
{*                                                                    *}
{* b) Der erste Fall trifft genau dann nicht zu, wenn das Kopfliteral *}
{*    eine vom Uebersetzer erzeugte Teilregel repraesentiert. Dann    *}
{*    sind alle Auftreten des Literals in der uebergebenen Regel-     *}
{*    menge enthalten und die Stelligkeit kann veraendert werden.     *}
{*                                                                    *}
{*--------------------------------------------------------------------*}
#MODE( buildArgumentMasks(i,o))


buildArgumentMasks([],[]).
buildArgumentMasks([rule(_head,_bodyLits)|_ruleTermListIn],[newHead(_functor,_headMask)|_newHeads]) :-
	_head =.. [_functor|_],
	findRulesForHead(_head,_ruleTermListIn,_otherRules,_remRules),
	findArgumentMaskForHead([rule(_head,_bodyLits)|_otherRules],_headMask),
	buildArgumentMasks(_remRules,_newHeads).

{*--------------------------------------------------------------------*}
{*                                                                    *}
{* findRulesForHead:                                                  *}
{* Eingabe: Kopfliteral l                                             *}
{*          Regelmenge  r                                             *}
{* Ausgabe: Menge 1: Alle Regeln aus r mit Kopfliteral l              *}
{*          Menge 2: alle anderen Regeln aus r                        *}
{*                                                                    *}
{*--------------------------------------------------------------------*}
#MODE( findRulesForHead(i,i,o,o))

findRulesForHead(_,[],[],[]).
findRulesForHead(_head,[rule(_head,_literals)|_rtListIn],[rule(_head,_literals)|_rtListHead],_otherRules) :-
	!,
	findRulesForHead(_head,_rtListIn,_rtListHead,_otherRules).
findRulesForHead(_head,[rule(_otherHead,_literals)|_rtListIn],_rtListHead,[rule(_otherHead,_literals)|_otherRules]) :-
	findRulesForHead(_head,_rtListIn,_rtListHead,_otherRules).


{*--------------------------------------------------------------------*}
{*                                                                    *}
{* findArgumentMaskForHead                                            *}
{* Eingabe: Regelmenge zu einem Kopfliteral                           *}
{* Ausgabe: Maske fuer die Argumente des Kopfliterals                 *}
{*                                                                    *}
{* Fuer jeden Regelrumpf wird festgestellt, welche variablen Argumente*}
{* des Kopfliterals im Rumpf verwendet werden. Wird eine Variable in  *}
{* keinem Regelrumpf verwendet, so ist das Berechnungsergebnis von    *}
{* der Belegung dieser Variablen unabahaengig.                        *}
{*                                                                    *}
{* Diese Information wird je Regelrumpf mit einer Maske codiert,      *}
{* welche fuer jedes Argument des Kopfliterals die folgenden          *}
{* Eintraege enthaelt:                                                *}
{*                                                                    *}
{* 1: Argument ist eine Konstante oder                                *}
{*    Argument ist eine Variable und tritt im Rumpf auf               *}
{* 0: Argument ist eine Variable und tritt nicht im Rumpf auf         *}
{*                                                                    *}
{* Die Masken der Regelruempfe werden anschliessend mit or miteinander*}
{* verknuepft. Sind saemtliche Eintraege 0, so wird aus Sicherheits-  *}
{* gruenden das erste Argument als einziges als noch benoetigt        *}
{* markiert. Dadurch wird verhindert, dass Literale ohne Argumente    *}
{* auftreten.                                                         *}
{*                                                                    *}
{*--------------------------------------------------------------------*}
#MODE( findArgumentMaskForHead(i,o))

findArgumentMaskForHead(_ruleList,_newHeadMask) :-
	buildHeadMaskList(_ruleList,_headMaskList),
	orMaskList(_headMaskList,_newHeadMask1),
	ensureAtLeastOneArg(_newHeadMask1,_newHeadMask),!.


#MODE( buildHeadMaskList(i,o))

buildHeadMaskList([],[]).
buildHeadMaskList([_ruleTerm|_ruleTerms],[_mask|_maskList]) :-
	buildHeadMaskForRule(_ruleTerm,_mask),
	buildHeadMaskList(_ruleTerms,_maskList).


#MODE( buildHeadMaskForRule(i,o))


buildHeadMaskForRule(rule(_head,_literals),_headMask) :-
	dynamicArgumentList(_head),!,
	getVarsList(_literals,_varsInLits),
	_head =.. [_|_argsHead],
	buildHeadMask(_argsHead,_varsInLits,_headMask).
buildHeadMaskForRule(rule(_head,_literals),_headMask) :-
	_head =.. [_|_argsHead],
	setAllOne(_argsHead,_headMask).

#MODE( buildHeadMask(i,i,o))

buildHeadMask([],_,[]).
buildHeadMask([_argInHead|_argsInHead],_varsInLits,[1|_mask]) :-
	isConst(_argInHead),!,
	buildHeadMask(_argsInHead,_varsInLits,_mask).
buildHeadMask([_argInHead|_argsInHead],_varsInLits,[1|_mask]) :-
	memberchk(_argInHead,_varsInLits),!,
	buildHeadMask(_argsInHead,_varsInLits,_mask).
buildHeadMask([_argInHead|_argsInHead],_varsInLits,[0|_mask]) :-
	buildHeadMask(_argsInHead,_varsInLits,_mask).

#MODE( dynamicArgumentList(i))

dynamicArgumentList(_head) :-
	_head =.. [_functor|_],
	pc_atomprefix('ID_',3,_functor),!.

#MODE( ensureAtLeastOneArg(i,o))

ensureAtLeastOneArg(_mask,[1]) :-
	allNull(_mask),!.
ensureAtLeastOneArg(_mask,_mask).


