#!/bin/sh

# make-executable: Make the ConceptBase.cc binaries executable.
# (c) 2013-2015 Manfred Jeusfeld

# Use this script if you installed ConceptBase under Linux/Unix and
# did not use CBinstaller but just unzipped the file cb-*.zip.
# This script does nothing fancy. Just sets the executable flag
# of ConceptBase program files and scripts. It also initializes the system
# database. Call it within the
# installation directory of ConceptBase. The script sets the file
# executable for everybody. If you want to limit the rights, just use
# 'ug' (user&group) or 'u' (only user) instead of 'ugo' (user-group-others).
#
# Call: sh make-executable

chmod ugo+x cb*
#chmod ugo+x start*
#chmod ugo+x bin/CB*

for subdir in "linux" "linux64" "sun4" "i86pc" 
  do
    if [ -x $subdir/bin/CBserver ]; then
      chmod  ugo+x $subdir/bin/CBserver
    fi
  done 

 
# create a plain database with just the SYSTEM files; also done by CBinstaller
# but we do it here as well for people who do a manual ConceptBase install

if [ ! -d "lib/SystemDB" ]; then
  mkdir lib/SystemDB
fi

cp lib/system/SYSTEM.SWI.telos lib/SystemDB/OB.telos
cp lib/system/SYSTEM.SWI.symbol lib/SystemDB/OB.symbol
cp lib/system/SYSTEM.SWI.rule lib/SystemDB/OB.rule
cp lib/system/SYSTEM.SWI.ruleinfo lib/SystemDB/OB.ruleinfo
cp lib/system/SYSTEM.SWI.ecarule lib/SystemDB/OB.ecarule


echo "SystemDB initialized; ConceptBase scripts and binaries set executable."







