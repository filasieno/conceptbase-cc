     /** compute how much larger than the bounding rectangle a small component should be depending 
         on the shape. For example, a Damond shape is very narrow left and right so that the
         label of the small component overlaps with the border of the diamond. By making it larger,
         we take care for more readable nopde layouts
      * @param shapeName The name of the shape, e.g. "i5.cb.graph.shapes.Ellipse"
      */

    protected static Dimension addedShapeSize(String shapeName) {
      if (shapeName.equals("i5.cb.graph.shapes.Rect"))
         return new Dimension(0,0);
      else if (shapeName.equals("i5.cb.graph.shapes.DiRect"))
         return new Dimension(20,0);
      else if (shapeName.equals("i5.cb.graph.shapes.Ellipse"))
         return new Dimension(16,4);
      else if (shapeName.equals("i5.cb.graph.shapes.Diamond"))
         return new Dimension(18,8);
      else if (shapeName.equals("i5.cb.graph.shapes.Triangle"))
         return new Dimension(18,8);
      else if (shapeName.equals("i5.cb.graph.shapes.TriangleR"))
         return new Dimension(15,8);
      else if (shapeName.equals("i5.cb.graph.shapes.TriangleL"))
         return new Dimension(15,8);
      else if (shapeName.equals("i5.cb.graph.shapes.DownTriangle"))
         return new Dimension(15,8);
      else if (shapeName.equals("i5.cb.graph.shapes.Hexagon"))
         return new Dimension(15,8);
      else if (shapeName.equals("i5.cb.graph.shapes.UpHexagon"))
         return new Dimension(10,6);
      else if (shapeName.equals("i5.cb.graph.shapes.House"))
         return new Dimension(10,6);
      else if (shapeName.equals("i5.cb.graph.shapes.Star"))
         return new Dimension(12,6);
      else if (shapeName.equals("i5.cb.graph.shapes.Octagon"))
         return new Dimension(18,2);
      else if (shapeName.equals("i5.cb.graph.shapes.Pentagon"))
         return new Dimension(20,8);
      else if (shapeName.equals("i5.cb.graph.shapes.Septagon"))
         return new Dimension(15,8);
      else if (shapeName.equals("i5.cb.graph.shapes.DownPentagon"))
         return new Dimension(20,8);
      else
         return new Dimension(0,0);
    }

}//CBUserObject

