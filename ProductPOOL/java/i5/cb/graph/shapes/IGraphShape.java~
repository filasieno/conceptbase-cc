package i5.cb.graph.shapes;

import java.awt.Color;
import java.awt.Dimension;

public interface IGraphShape{

	public final Color DEFAULT_FILL_COLOR = Color.red;

	public final Color DEFAULT_OUTLINE_COLOR = Color.black;

	public void setFillColor(Color c);

	public Color getFillColor();

	public void setOutlineColor(Color c);

	public Color getOutlineColor();

    public void setLineWidth(float w);

    public float getLineWidth();

     /** compute how much larger than the bounding rectangle a small component should be depending 
         on the shape. For example, a Damond shape is very narrow left and right so that the
         label of the small component overlaps with the border of the diamond. By making it larger,
         we take care for more readable nopde layouts
      * @param shapeName The name of the shape, e.g. "i5.cb.graph.shapes.Ellipse"
      */

    public static Dimension addedShapeSize(String shapeName);

}
