# Nix build symlinks
result*
result.*
.direnv
# CMake (per-component build dirs)
components/*/build/

# Build outputs (Maven, Cargo, tree-sitter, etc.)
target/
components/java/**/target/
compile_commands.json

# Flex/Bison — generated at build time, never commit
components/**/src/*.tab.c
components/**/src/*.tab.h
components/**/src/*.yy.c

# Local tooling cache
.cache/

# Node / TypeScript build outputs (mmkit and other JS workspaces)
**/node_modules/
**/dist/
**/out/
**/coverage/
*.tsbuildinfo

# Codegen — regenerate at build time, never commit
**/*.gen.ts

# Local debug logs
error.log
stat.log
**/error.log
**/stat.log

# IDE (keep workspace settings; ignore personal overrides)
.idea/
.vscode/*.local.json
*.iml
