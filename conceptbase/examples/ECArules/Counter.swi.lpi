
/* Prolog predicates for counter example. */
/* Must be loaded together with Counter.sml */
/* Copy this file to your database directory */
/* before you start the ConceptBase Server! */

/* The input of this predicate is variable _id, an OID of an Integer */
increment(_id,_new) :-
    'GeneralUtilities':id2name(_id,_a),   /* convert it to a PROLOG atom */
    term_to_atom(_i,_a),        /* convert it to a PROLOG int */
    integer(_i),
    _i1 is _i + 1 ,          /* increment it */
    term_to_atom(_i1,_new).     /* make an atom out of it */

/* The input of this predicate is variable _id, an OID of an Integer */
decrement(_id,_new) :-
    'GeneralUtilities':id2name(_id,_a),   /* convert it to a PROLOG atom */
    term_to_atom(_i,_a),        /* convert it to a PROLOG int */
    integer(_i),
    _i1 is _i - 1 ,          /* decrement it */
    term_to_atom(_i1,_new).     /* make an atom out of it */

