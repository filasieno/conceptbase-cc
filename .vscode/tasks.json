{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mmkit: build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/components/mmkit"
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "mmkit: watch",
      "type": "shell",
      "command": "npm run watch",
      "options": {
        "cwd": "${workspaceFolder}/components/mmkit"
      },
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
