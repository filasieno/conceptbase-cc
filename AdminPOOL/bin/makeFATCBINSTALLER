#!/bin/sh
# make a fat CBinstaller.jar that contains the ConceptBase binaries

CBDISTROS=$HOME/ConceptBase-Distros
CBINSTALLER=$HOME/CBPOOL/ProductPOOL/java/classes/CBinstaller.jar

if [ -d $HOME/ConceptBase-Distros/CBinstaller ] ; then
  /bin/rm -rf $HOME/ConceptBase-Distros/CBinstaller
fi

cd $HOME/ConceptBase-Distros

if [ ! -f $CBINSTALLER ] ; then
  echo "No CBinstaller.jar found in CBPOOL"
  exit
fi

mkdir CBinstaller
cd CBinstaller
unzip $CBINSTALLER

cp -r $CBDISTROS/CB-LATEST/* .

if [ -f $CBDISTROS/CBinstaller.jar ] ; then
  /bin/rm -f $CBDISTROS/CBinstaller.jar
fi

zip -r ../CBinstaller.jar *

cp $CBINSTALLER $CBDISTROS/thin-CBinstaller.jar

echo "Created fat CBinstaller.jar in $CBDISTROS."


