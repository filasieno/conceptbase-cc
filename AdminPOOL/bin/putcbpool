#!/bin/sh
# put the current CBPOOL to USBstick or local ConceptBaseCC-SourceForge folder after compiling it
# This script is perhaps useful in distributing the CBPOOL.zip archive.
# This is used to create CBPOOL.zip to be shared on Sourceforge
# Author: Manfred Jeusfeld

STICKDIR=$HOME/ConceptBaseCC-SourceForge/

# some USB sticks used by me
if [ -d /media/$USER/K707 ]; then
  STICKDIR=/media/$USER/K707/
elif [ -d /media/$USER/USB_DISK ]; then
  STICKDIR=/media/$USER/USB_DISK/
elif [ -d /media/$USER/TOSHIBA ]; then
  STICKDIR=/media/$USER/TOSHIBA/

fi


if [ -d "$STICKDIR" ]; then

cd $HOME/CBPOOL/ProductPOOL
  compileCB
  /bin/rm -rf $HOME/CBPOOL/ProductPOOL/linux*/serverSources/Prolog_Files/objects.SWI/PrologObjects
  cd $HOME
  /bin/rm $STICKDIR/CBPOOL.zip
#  zip -r $STICKDIR/CBPOOL.zip CBPOOL -x \*.git* CBPOOL/ProductPOOL/doc/UserManual/**\*
  zip -r $STICKDIR/CBPOOL.zip CBPOOL -x \*.git* CBPOOL/ProductPOOL/doc/UserManual/hevea/**\*
  echo "CBPOOL.zip created and copied to $STICKDIR"
else
  echo "No USB stick or Dropbox folder found"
fi

exportCB

