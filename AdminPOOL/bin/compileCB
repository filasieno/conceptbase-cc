#!/bin/sh
# Compile the ConceptBase sources
# To do so, all required tools and libraries
# must be installed and configured correctly.
# Use "compileCB -all" when the sources are compiled for the first time on a new platform
# Thereafter, a simple "compileCB" is sufficient
# Author: Manfred Jeusfeld (2021-07-08)

cd $HOME

export CB_VARIANT="`CBvariant`"
echo "Compiling for $CB_VARIANT"

export JAVAC_VERSION="`javac -version`"
echo "Using Javac version $JAVAC_VERSION"


if [ "$1" = "-all"  ]; then
  (cd $CB_WORK/; CB_Make clean)
fi

(cd $CB_WORK/; CB_Make touch_src)
echo 'Converting dcg ...'
(cd $CB_WORK/serverSources/Prolog_Files; CB_Make dcg)  
echo 'Compiling ...'
(cd $CB_WORK/;  CB_Make all)  
echo 'Installing ...'
(cd $CB_WORK/; CB_Make export; CB_Make install) 1> /dev/null 2> /dev/null
echo 'done'








