#!/bin/sh
# copy the platform binaries to Dropbox folder; this script is designed
# for the make environment used by Manfred Jeusfeld

STICKDIR=$HOME/Dropbox/

# some USB sticks used by me
if [ -d /media/$USER/K707 ]; then
  STICKDIR=/media/$USER/K707/
elif [ -d /media/$USER/USB_DISK ]; then
  STICKDIR=/media/$USER/USB_DISK/
elif [ -d /media/$USER/TOSHIBA ]; then
  STICKDIR=/media/$USER/TOSHIBA/
fi

CB_VARIANT=`CBvariant`
cp -rf $HOME/CBPOOL/conceptbase/$CB_VARIANT $STICKDIR/CB-PLATFORMS

if [ -d $SWI_HOME/lib/swipl-6.6.6/lib/`arch`-linux/ ]; then
	echo Copying libswipl.so 
	cp $SWI_HOME/lib/swipl-6.6.6/lib/`arch`-linux/libswipl.so.* $STICKDIR/CB-PLATFORMS/$CB_VARIANT/lib
fi
