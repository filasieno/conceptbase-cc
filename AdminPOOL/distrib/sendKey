#!/bin/csh
# This script takes as input on stdin the mail
# that has been generated by cbreg.cgi and extracts
# the information which is necessary to send a reply,
# i.e. a mail with the registration code and a short
# mail explaining how to install the registration code
#
# The script has one argument: the number of months
# for which the registration code should be valid. If
# the argument is ommitted or is 0, the regristration code
# will be valid for ever. (see also makeKey.c)
#
# Example Usage:
# The script has to be used by the user "cb" within
# the "mail" program ( /usr/ucb/mail ).
# A mail from the registration CGI program is piped
# into this script using the pipe command in mail:
#    pipe 2 "sendKey 6"
# will send the mails to the user specified in the 
# second mail. The registration code will be valid
# for 6 months.


setenv tmpfile /tmp/tmpcbmail
setenv infofile /home/cbase/CB_NewStruct/CB_Admin/distrib/mail.txt

rm -f $tmpfile
gawk -f /home/cbase/CB_NewStruct/CB_Admin/distrib/sendKey.awk > $tmpfile

chmod 700 $tmpfile
source $tmpfile
/bin/rm -f $tmpfile

if ( "$1" == "" ) then
	setenv dauer 0
else
	setenv dauer $1
endif

echo Sending key to: $email
echo Name: $name
echo Org: $uni
echo Valid for $dauer months


touch $tmpfile
echo To: $email >> $tmpfile
echo Cc: cb@i5.informatik.rwth-aachen.de >> $tmpfile
echo >> $tmpfile
echo Dear $name! >> $tmpfile
cat $infofile >> $tmpfile

mail -t -s "Registration key following..."  < $tmpfile

rm -f $tmpfile

touch $tmpfile
echo To: $email >> $tmpfile
echo Cc: cb@i5.informatik.rwth-aachen.de >> $tmpfile
echo >> $tmpfile
/home/cbase/CB_NewStruct/CB_Admin/distrib/makeKey $dauer >> $tmpfile
echo $name >> $tmpfile
echo $uni >> $tmpfile

mail -t -s "Registration key"  < $tmpfile

rm -f $tmpfile

