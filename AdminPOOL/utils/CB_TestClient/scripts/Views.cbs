result OK "Michael in EmpDept2 with 
  dept
     MichaelsDepartment : Production
  salary
     MichaelsSalary : 30000
end 

Max in EmpDept2 with 
  dept
     MaxDepartment : Production
  salary
     MaxSalary : 40000
end 

