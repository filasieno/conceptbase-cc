startServer -d Views -U verbatim
tellModel "$CB_HOME/examples/QUERIES/Employee_Classes"
result OK "yes"
tellModel "$CB_HOME/examples/QUERIES/Employee_Instances"
result OK "yes"
ask "get_object[View/objname]" OBJNAMES  FRAME  Now
result OK "Individual View in Class isA GenericQueryClass with 
  attribute
     partof : Proposition;
     inherited_attribute : Proposition
end"
tell "View EmpDept isA Employee with
retrieved_attribute, partof
    dept : Department with
        retrieved_attribute
            head : Manager
    end
end"
result OK "yes"
ask "get_object[EmpDept/objname]" OBJNAMES  FRAME  Now
result OK "Individual EmpDept in View isA Employee with 
  attribute,partof,retrieved_attribute
     dept : SV_EmpDept_dept
end"
ask "get_object[SV_EmpDept_dept/objname]" OBJNAMES  FRAME  Now
result OK "Individual SV_EmpDept_dept in SubView isA Department with 
  attribute,retrieved_attribute
     head : Manager
end"
