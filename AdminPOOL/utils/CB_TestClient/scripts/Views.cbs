tell "Employee with attribute likes : Employee end
Mary with likes ml : Eleonore end"
result OK "yes"
tell "View EmpDept_likes_head isA Employee with
retrieved_attribute,partof
    dept : Department with
        retrieved_attribute, partof
            head : Manager with
                constraint c : $ A(this,likes,this::dept::head) $
        end
    end
end"
ask "EmpDept_likes_head" OBJNAMES FRAME Now
result OK "Mary in EmpDept_likes_head with 
  dept
     MarysDepartment : Administration[Mary/this_par] with 
       head
          Boss_of_Administration : Eleonore[Mary/this_par] 
     end 
     end 
end"
